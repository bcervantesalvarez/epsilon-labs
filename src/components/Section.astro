---
// src/components/Section.astro
// Standard editorial section with optional eyebrow + title + trailing link.
// Sits inside <main class="ed"> so alternating-bg styling applies.
interface Props {
  eyebrow?: string;
  title?: string;
  link?: { href: string; label: string };
  id?: string;
  first?: boolean;        // Skip top divider on the first section
  contentClass?: string;  // Extra class on the inner wrap
  reveal?: boolean;       // Fade-in on first scroll into view.
                          // Defaults to on, except for `first` sections
                          // (likely above the fold — no flash of hidden
                          // content while the observer boots).
}

const { eyebrow, title, link, id, first, contentClass = '', reveal } = Astro.props;
const shouldReveal = reveal ?? !first;
const sectionClass = [
  'py-24 lg:py-28',
  first ? 'pt-8 lg:pt-10' : '',
].filter(Boolean).join(' ');
---
<section id={id} class={sectionClass} data-reveal={shouldReveal ? '' : undefined}>
  <div class={`max-w-wrap mx-auto px-6 ${contentClass}`}>
    {eyebrow && (
      <p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted mb-5 mt-0">
        {eyebrow}
      </p>
    )}

    {(title || link) && (
      <div class="flex flex-wrap items-baseline justify-between gap-4 mb-10">
        {title && (
          <h2 class="font-serif font-semibold text-ink text-4xl md:text-5xl tracking-tight leading-[1.08] m-0">
            {title}
          </h2>
        )}
        {link && (
          <a href={link.href} class="text-sm text-muted hover:text-ink border-b border-rule hover:border-ink no-underline pb-px">
            {link.label} →
          </a>
        )}
      </div>
    )}

    <slot />
  </div>
</section>
