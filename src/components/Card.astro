---
// src/components/Card.astro
// Clickable project/post card. 1px border at rest, border darkens on hover,
// image zooms slightly. No drop-shadow.
interface Props {
  href: string;
  title: string;
  description?: string;
  tag?: string;
  image?: string;
  imageAlt?: string;
  external?: boolean;
}

const { href, title, description, tag, image, imageAlt = '', external } = Astro.props;
const target = external ? '_blank' : undefined;
const rel = external ? 'noreferrer' : undefined;
---
<a
  href={href}
  target={target}
  rel={rel}
  class="group block bg-surface border border-rule rounded-xl overflow-hidden no-underline transition-colors hover:border-ink"
>
  {image && (
    <div class="aspect-[16/10] bg-surface-soft border-b border-rule overflow-hidden">
      <img
        src={image}
        alt={imageAlt}
        loading="lazy"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.025]"
      />
    </div>
  )}
  <div class="px-6 pt-5 pb-7">
    {tag && (
      <p class="text-[0.7rem] font-semibold uppercase tracking-[0.12em] text-accent-ink m-0 mb-2">
        {tag}
      </p>
    )}
    <h3 class="font-sans font-bold text-ink text-lg leading-snug mt-0 mb-2">
      {title}
    </h3>
    {description && (
      <p class="text-sm text-muted leading-relaxed m-0">
        {description}
      </p>
    )}
  </div>
</a>
