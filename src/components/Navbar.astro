---
// src/components/Navbar.astro
// Edit `links` to change top-level navigation.
import epsilonMark from '@/assets/logo/epsilon-mark.svg?raw';

const links = [
  { href: '/about',     label: 'About'     },
  { href: '/services',  label: 'Services'  },
  { href: '/projects',  label: 'Projects'  },
  { href: '/blog',      label: 'Blog'      },
  { href: '/talks',     label: 'Talks'     },
  { href: '/resources', label: 'Resources' },
];

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---
<header class="sticky top-0 z-50 border-b border-rule bg-bg/90 backdrop-blur supports-[backdrop-filter]:bg-bg/75">
  <nav class="relative max-w-wrap mx-auto px-6 py-4 flex items-center justify-between gap-6" aria-label="Main">
    <a href="/" class="group inline-flex items-center gap-2.5 font-bold text-ink text-base tracking-tight no-underline hover:no-underline">
      <span class="brand-mark inline-flex text-ink transition-transform duration-300 group-hover:rotate-[-8deg]" aria-hidden="true">
        <Fragment set:html={epsilonMark} />
      </span>
      Epsilon&nbsp;Labs
    </a>

    <ul class="hidden md:flex items-center gap-1 list-none m-0 p-0">
      {links.map(l => (
        <li class="m-0">
          <a
            href={l.href}
            class:list={[
              'inline-block px-3 py-2 rounded-lg font-medium text-sm transition-colors',
              'no-underline',
              isActive(l.href)
                ? 'text-ink bg-surface-soft'
                : 'text-body hover:text-ink hover:bg-surface-soft',
            ]}
          >
            {l.label}
          </a>
        </li>
      ))}
    </ul>

    <button
      type="button"
      data-search-open
      aria-label="Open site search"
      title="Search (⌘K)"
      class="text-body hover:text-ink p-2 rounded-lg hover:bg-surface-soft transition-colors"
    >
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8" />
        <line x1="21" y1="21" x2="16.65" y2="16.65" />
      </svg>
    </button>

    <button
      id="nav-toggle"
      type="button"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-nav"
      class="md:hidden text-body hover:text-ink p-2 rounded-lg hover:bg-surface-soft transition-colors"
    >
      <svg class="nav-icon-open w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="4" y1="7" x2="20" y2="7" />
        <line x1="4" y1="12" x2="20" y2="12" />
        <line x1="4" y1="17" x2="20" y2="17" />
      </svg>
      <svg class="nav-icon-close w-5 h-5 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="6" y1="6" x2="18" y2="18" />
        <line x1="6" y1="18" x2="18" y2="6" />
      </svg>
    </button>

    <button
      id="theme-toggle"
      aria-label="Toggle color theme"
      class="text-body hover:text-ink p-2 rounded-lg hover:bg-surface-soft transition-colors"
    >
      <svg class="w-5 h-5 hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="5"/>
        <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <svg class="w-5 h-5 block dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
  </nav>

  <!-- Mobile navigation panel: slides down under the header bar.
       Hidden entirely at md+ where the inline links take over. -->
  <div
    id="mobile-nav"
    hidden
    class="md:hidden absolute top-full inset-x-0 border-b border-rule bg-bg shadow-[0_24px_50px_-30px_color-mix(in_srgb,var(--color-ink)_40%,transparent)]"
  >
    <nav aria-label="Mobile">
      <ul class="list-none m-0 px-4 py-3 flex flex-col">
        {links.map(l => (
          <li class="m-0">
            <a
              href={l.href}
              class:list={[
                'block px-4 py-3.5 rounded-xl font-semibold text-base no-underline transition-colors',
                isActive(l.href)
                  ? 'text-ink bg-surface-soft'
                  : 'text-body hover:text-ink hover:bg-surface-soft',
              ]}
              aria-current={isActive(l.href) ? 'page' : undefined}
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  /* The inline mark ships at 1em intrinsic size; :global reaches the
     set:html-injected svg that scoped attributes can't. */
  .brand-mark :global(svg) {
    width: 1.35rem;
    height: 1.35rem;
  }

  /* Mobile panel entrance. [hidden] handles display; the animation
     runs each time it opens. Instant under reduced motion. */
  #mobile-nav:not([hidden]) {
    animation: nav-drop 0.28s cubic-bezier(0.2, 0, 0.2, 1);
  }
  @keyframes nav-drop {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  #nav-toggle[aria-expanded="true"] :global(.nav-icon-open)  { display: none; }
  #nav-toggle[aria-expanded="true"] :global(.nav-icon-close) { display: block; }
  @media (prefers-reduced-motion: reduce) {
    #mobile-nav:not([hidden]) { animation: none; }
  }
</style>

<script>
  // Everything is delegated: the nodes are replaced on every
  // ClientRouter swap, but document-level listeners survive. After a
  // swap the fresh panel arrives closed (server-rendered [hidden]).
  function setMenu(open: boolean) {
    const panel = document.getElementById('mobile-nav');
    const toggle = document.getElementById('nav-toggle');
    if (!panel || !toggle) return;
    panel.hidden = !open;
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  }

  document.addEventListener('click', (e) => {
    const t = e.target instanceof Element ? e.target : null;
    if (!t) return;

    if (t.closest('#theme-toggle')) {
      const html = document.documentElement;
      const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      try { localStorage.setItem('theme', next); } catch (err) { /* no-op */ }
      html.setAttribute('data-theme', next);
      return;
    }

    const panel = document.getElementById('mobile-nav');
    if (!panel) return;
    if (t.closest('#nav-toggle')) {
      setMenu(panel.hidden);
    } else if (!panel.hidden && (t.closest('#mobile-nav a') || !t.closest('header'))) {
      // A tapped panel link or a tap anywhere outside the header closes it.
      setMenu(false);
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    const panel = document.getElementById('mobile-nav');
    if (!panel || panel.hidden) return;
    setMenu(false);
    document.getElementById('nav-toggle')?.focus();
  });
</script>
