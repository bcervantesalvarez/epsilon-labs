---
// src/components/SearchModal.astro
// Site-wide search modal backed by Pagefind.
// In dev mode `/pagefind/` does not exist, so the modal will say
// "indexing pending". After `npm run build` (which runs pagefind),
// it's fully functional.
---
<dialog
  id="search-dialog"
  class="search-dialog bg-bg text-body backdrop:bg-ink/40 backdrop:backdrop-blur-sm rounded-2xl border border-rule shadow-2xl max-w-2xl w-[92vw] p-0 m-auto top-[14vh]"
>
  <div class="flex items-center justify-between px-5 py-3 border-b border-rule">
    <h2 class="text-sm font-semibold uppercase tracking-[0.14em] text-muted m-0">
      Search
    </h2>
    <button
      type="button"
      aria-label="Close search"
      onclick="document.getElementById('search-dialog').close()"
      class="text-muted hover:text-ink p-1 rounded transition-colors"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </div>

  <div class="p-5">
    <div id="search-target" class="search-target"></div>
    <p id="search-fallback" class="text-sm text-muted m-0 hidden">
      Search isn't indexed yet. Run <code class="text-xs">npm run build</code> to
      generate the index, then refresh.
    </p>
  </div>
</dialog>

<!-- Pagefind UI CSS is appended dynamically on first open, so dev mode
     (where /pagefind/ doesn't exist yet) doesn't 404 on every page load. -->

<script is:inline>
  // Lazy-load the Pagefind UI bundle when the modal is first opened.
  // Marked is:inline so Vite skips its import analyzer on the dynamic
  // import — `/pagefind/` only exists after `npm run build` runs
  // pagefind against `dist/`, so a build-time resolution would fail.
  (function () {
    let inited = false;

    // ClientRouter swaps replace the dialog + #search-target nodes and
    // strip the dynamically-added Pagefind assets from <head>, so the
    // UI must re-initialize on the next open after a navigation.
    document.addEventListener('astro:after-swap', () => { inited = false; });

    function ensureCss() {
      if (document.querySelector('link[data-pagefind-css]')) return;
      const link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = '/pagefind/pagefind-ui.css';
      link.setAttribute('data-pagefind-css', '');
      link.onerror = () => link.remove();
      document.head.appendChild(link);
    }

    async function initPagefind() {
      if (inited) return;
      inited = true;
      ensureCss();
      try {
        // Compose the URL at runtime so Vite's static analyzer can't
        // see a literal — /* @vite-ignore */ alone is not enough when
        // Astro bundles a module script.
        const url = '/' + 'pagefind/pagefind-ui.js';
        const mod = await import(url);
        const PagefindUI =
          (mod && (mod.PagefindUI || (mod.default && mod.default.PagefindUI))) ||
          window.PagefindUI;
        if (!PagefindUI) throw new Error('PagefindUI not found in /pagefind/pagefind-ui.js');
        new PagefindUI({
          element: '#search-target',
          resetStyles: false,
          showImages: false,
          showSubResults: true,
          excerptLength: 18,
        });
      } catch (e) {
        const fb = document.getElementById('search-fallback');
        if (fb) fb.classList.remove('hidden');
        console.warn('Pagefind UI not available (run `npm run build` to generate /pagefind/):', e);
      }
    }

    function openSearch() {
      const dlg = document.getElementById('search-dialog');
      if (!dlg) return;
      dlg.showModal();
      initPagefind().then(() => {
        const input = document.querySelector('#search-target input');
        if (input) input.focus();
      });
    }

    document.addEventListener('click', (e) => {
      const t = e.target;
      if (t instanceof Element && t.closest('[data-search-open]')) {
        e.preventDefault();
        openSearch();
      }
    });

    document.addEventListener('keydown', (e) => {
      const meta = e.metaKey || e.ctrlKey;
      if (meta && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        openSearch();
      }
    });
  })();
</script>

<style is:global>
  /* Tune the Pagefind UI defaults to match the editorial palette. */
  .pagefind-ui {
    --pagefind-ui-scale: 0.95;
    --pagefind-ui-primary: var(--color-ink);
    --pagefind-ui-text: var(--color-body);
    --pagefind-ui-background: var(--color-bg);
    --pagefind-ui-border: var(--color-rule);
    --pagefind-ui-tag: var(--color-surface-soft);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 10px;
    --pagefind-ui-font: var(--font-sans);
  }
  .pagefind-ui__search-input {
    background: var(--color-surface) !important;
  }
  .pagefind-ui__result-title {
    font-family: var(--font-serif);
    font-weight: 600;
  }
</style>
