---
// src/components/Embed.astro
// Full-bleed iframe wrapper used for revealjs talks and dashboard apps.
// Targets a clean fixed aspect with a generous minimum height; no
// shadow, single hairline border, rounded corners matching the rest
// of the editorial system.
interface Props {
  src: string;
  title: string;
  /** "talk" → 16:9 letterbox; "app" → 4:3-ish with a higher minimum */
  variant?: 'talk' | 'app';
}

const { src, title, variant = 'talk' } = Astro.props;
const aspect = variant === 'talk' ? 'aspect-video' : 'aspect-[4/3]';
const minH = variant === 'talk' ? 'min-h-[560px]' : 'min-h-[720px]';
---
<figure class="my-8 w-full">
  <div class={`relative w-full ${aspect} ${minH} rounded-xl border border-rule overflow-hidden bg-surface`}>
    <iframe
      src={src}
      title={title}
      loading="lazy"
      allow="fullscreen"
      class="absolute inset-0 w-full h-full border-0"
    />
  </div>
  <figcaption class="mt-3 text-xs text-muted text-center">
    <a href={src} target="_blank" rel="noreferrer" class="hover:text-ink no-underline">
      Open {title} in a new tab ↗
    </a>
  </figcaption>
</figure>
