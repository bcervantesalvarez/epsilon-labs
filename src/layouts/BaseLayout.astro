---
// src/layouts/BaseLayout.astro
// Site shell: <html>, <head>, navbar, footer. Every page should use this.
import Navbar from '@components/Navbar.astro';
import Footer from '@components/Footer.astro';
import ScrollTop from '@components/ScrollTop.astro';
import SearchModal from '@components/SearchModal.astro';
import { ClientRouter } from 'astro:transitions';
import { SITE_NAME, SITE_DESCRIPTION, AUTHOR, absoluteUrl } from '@lib/site';
// Self-hosted fonts via @fontsource — no render-blocking Google Fonts
// request. Newsreader ships as a variable font with the opsz axis so
// large serif headlines keep the display cut (matching the old CDN
// opsz 6..72 load). The static @fontsource/newsreader stays a dep for
// Satori's build-time OG images, which need fixed instances.
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource-variable/newsreader/opsz.css';
import '@styles/global.css';

interface Props {
  title?: string;
  description?: string;
  // Path under /og/ for a build-time generated card, e.g. "blog/my-post".
  // When omitted, the shared /og/default.png is used.
  ogPath?: string;
  // Escape hatch for explicit static images (e.g. legacy assets).
  ogImage?: string;
}

const {
  title = SITE_NAME,
  description = `${SITE_DESCRIPTION.replace(/\.$/, '')} by ${AUTHOR.name}.`,
  ogPath,
  ogImage,
} = Astro.props;

const fullTitle = title === SITE_NAME ? title : `${title} · ${SITE_NAME}`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const resolvedOg = ogImage ?? `/og/${ogPath ?? 'default'}.png`;
---
<!doctype html>
<html lang="en" data-theme="light">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <!-- Mobile browser chrome color; kept in sync with the active theme
       by the applyTheme script below. -->
  <meta name="theme-color" content="#fbfaf7" />
  <link rel="canonical" href={canonical} />

  <!-- Fluid page-to-page transitions (View Transitions API with a
       same-document fallback). Reduced-motion users get instant swaps
       via the media query in global.css. -->
  <ClientRouter />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link
    rel="alternate"
    type="application/rss+xml"
    title={`${SITE_NAME} — Insights`}
    href="/blog/rss.xml"
  />

  <!-- OpenGraph / Twitter -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={new URL(resolvedOg, Astro.site)} />
  <meta name="twitter:card" content="summary_large_image" />

  <!-- Per-page head extras (e.g. noindex metas, KaTeX on article routes) -->
  <slot name="head" />

  <!-- JSON-LD: Person + Organization. Search engines surface these
       in the knowledge panel + as rich results. Every absolute URL is
       derived from `site` in astro.config.ts via @lib/site. -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@graph': [
      {
        '@type': 'Person',
        '@id': absoluteUrl('/#brian'),
        name: AUTHOR.name,
        url: absoluteUrl('/'),
        image: absoluteUrl('/images/profile.jpg'),
        sameAs: [
          AUTHOR.linkedin,
          AUTHOR.github,
        ],
        jobTitle: AUTHOR.jobTitle,
        worksFor: {
          '@type': 'GovernmentOrganization',
          name: 'Oregon Department of Education',
          url: 'https://www.oregon.gov/ode/',
        },
        alumniOf: [
          { '@type': 'CollegeOrUniversity', name: 'Oregon State University', url: 'https://stat.oregonstate.edu/' },
          { '@type': 'CollegeOrUniversity', name: 'Willamette University', url: 'https://willamette.edu/academics/computing/data-science/' },
          { '@type': 'CollegeOrUniversity', name: 'Linfield University', url: 'https://www.linfield.edu/' },
        ],
        knowsAbout: [
          'Statistics', 'Statistical consulting', 'Predictive modeling',
          'Machine learning', 'Bayesian inference', 'Experimental design',
          'Data visualization', 'R', 'Python', 'SQL',
        ],
      },
      {
        '@type': 'Organization',
        '@id': absoluteUrl('/#epsilon-labs'),
        name: SITE_NAME,
        url: absoluteUrl('/'),
        founder: { '@id': absoluteUrl('/#brian') },
        description: SITE_DESCRIPTION,
      },
      {
        '@type': 'WebSite',
        '@id': absoluteUrl('/#website'),
        url: absoluteUrl('/'),
        name: SITE_NAME,
        publisher: { '@id': absoluteUrl('/#epsilon-labs') },
        inLanguage: 'en-US',
      },
    ],
  })} />

  <!-- Set theme before paint to avoid flash. Re-applied after every
       ClientRouter swap: the router replaces <html> attributes with
       the incoming page's, which would otherwise reset the theme. -->
  <script is:inline>
    (function () {
      function applyTheme() {
        try {
          const stored = localStorage.getItem('theme');
          const prefers = window.matchMedia('(prefers-color-scheme: dark)').matches
            ? 'dark' : 'light';
          const theme = stored || prefers;
          // Only write when different — the MutationObserver below
          // watches this attribute, and an unconditional write would
          // retrigger it forever.
          if (document.documentElement.getAttribute('data-theme') !== theme) {
            document.documentElement.setAttribute('data-theme', theme);
          }
          const meta = document.querySelector('meta[name="theme-color"]');
          if (meta) meta.setAttribute('content', theme === 'dark' ? '#0f1115' : '#fbfaf7');
        } catch (e) { /* no-op */ }
      }
      applyTheme();
      document.addEventListener('astro:after-swap', applyTheme);
      // The navbar toggle only flips the attribute — mirror changes
      // into the theme-color meta as well.
      new MutationObserver(applyTheme).observe(document.documentElement, {
        attributes: true, attributeFilter: ['data-theme'],
      });
    })();
  </script>

  <!-- Scroll reveal for [data-reveal] sections. Runs before paint so the
       hidden initial state (gated on html.reveal-ready) never flashes.
       Bails out entirely without JS, without IntersectionObserver, or
       when the user prefers reduced motion — content stays visible. -->
  <script is:inline>
    (function () {
      if (!('IntersectionObserver' in window)) return;
      if (!window.matchMedia('(prefers-reduced-motion: no-preference)').matches) return;
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-revealed');
            io.unobserve(entry.target);
          }
        });
      }, { rootMargin: '0px 0px -8% 0px', threshold: 0 });
      function arm() {
        document.documentElement.classList.add('reveal-ready');
        document.querySelectorAll('[data-reveal]:not(.is-revealed)').forEach(function (el) {
          io.observe(el);
        });
      }
      document.documentElement.classList.add('reveal-ready');
      document.addEventListener('DOMContentLoaded', arm);
      // ClientRouter swaps replace <html> attributes and the DOM —
      // re-stamp the gate class and observe the fresh sections.
      document.addEventListener('astro:after-swap', arm);
    })();
  </script>
</head>
<body class="bg-bg text-body font-sans text-base">
  <a href="#main" class="skip-link">Skip to content</a>
  <Navbar />
  <main id="main">
    <slot />
  </main>
  <Footer />
  <ScrollTop />
  <SearchModal />

  <!-- Iframe presentation mode:
       Native iframe fullscreen often fails to trigger revealjs's resize
       handler on cross-origin embeds, leaving slides at the small
       embedded scale. Instead, we toggle a `.present` class that lifts
       the iframe into a fixed full-viewport overlay; revealjs picks up
       the natural resize and scales correctly. Esc exits. -->
  <script>
    let active: HTMLElement | null = null;
    const exit = () => {
      if (!active) return;
      document.documentElement.classList.remove('iframe-presenting');
      active.classList.remove('present');
      active = null;
    };

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && active) {
        active.dispatchEvent(new Event('present:exit'));
        exit();
      }
    });
    // Leaving the page via the ClientRouter should never strand the
    // presentation overlay class on <html>.
    document.addEventListener('astro:before-swap', exit);

    function initIframes() {
      document.querySelectorAll('iframe').forEach((f) => {
        const cur = f.getAttribute('allow') || '';
        if (!cur.includes('fullscreen')) {
          f.setAttribute('allow', cur ? `${cur}; fullscreen` : 'fullscreen');
        }
        f.setAttribute('allowfullscreen', '');
      });

      document.querySelectorAll('.article-body iframe').forEach((f) => {
        if (f.parentElement?.classList.contains('iframe-shell')) return;

        const shell = document.createElement('div');
        shell.className = 'iframe-shell relative my-6';
        f.parentElement?.insertBefore(shell, f);
        shell.appendChild(f);

        const btn = document.createElement('button');
        btn.type = 'button';
        btn.setAttribute('aria-label', 'Open presentation full screen');
        btn.className =
          'iframe-fs absolute top-3 right-3 z-20 inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold rounded-full bg-ink text-bg shadow-md hover:bg-accent-ink focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink';
        btn.innerHTML =
          '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg><span class="fs-label">Full screen</span>';
        const setLabel = (text: string) => {
          const lbl = btn.querySelector('.fs-label');
          if (lbl) lbl.textContent = text;
        };
        btn.addEventListener('click', () => {
          if (shell.classList.contains('present')) {
            setLabel('Full screen');
            exit();
            return;
          }
          exit();
          shell.classList.add('present');
          document.documentElement.classList.add('iframe-presenting');
          active = shell;
          setLabel('Exit');
          // Nudge the iframe to recompute layout once the new size lands.
          requestAnimationFrame(() => {
            window.dispatchEvent(new Event('resize'));
          });
        });
        shell.appendChild(btn);

        shell.addEventListener('present:exit', () => setLabel('Full screen'));
      });
    }

    document.addEventListener('astro:page-load', initIframes);
    if (document.readyState !== 'loading') initIframes();
    else document.addEventListener('DOMContentLoaded', initIframes);
  </script>
</body>
</html>
