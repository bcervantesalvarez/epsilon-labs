---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/Section.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('talks', ({ data }) => !data.draft && data.status === 'active');
const talks = all.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) => d.toLocaleDateString('en-US',
  { year: 'numeric', month: 'long', day: 'numeric' });

// Two letters from the year for the marker stamp
const yearStamp = (d: Date) => String(d.getFullYear()).slice(-2);
---
<BaseLayout title="Talks" description="Workshops, lectures, and applied analyses presented to live audiences.">
  <div class="ed">

    <section class="pt-24 pb-10 lg:pt-28 lg:pb-12">
      <div class="max-w-wrap mx-auto px-6">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted m-0 mb-5">Talks</p>
        <h1 class="font-serif font-semibold text-ink text-5xl md:text-6xl tracking-tight leading-[1.06] m-0 mb-4">
          Live audiences.
        </h1>
        <p class="text-lede text-body max-w-[60ch] m-0">
          Workshops, lectures, and applied analyses. Each entry below
          embeds the original slide deck — click through to open the
          full presentation in a new tab or go fullscreen.
        </p>
      </div>
    </section>

    <Section first>
      {talks.length === 0 ? (
        <p class="text-body">New talks will be posted here.</p>
      ) : (
        <ol class="list-none m-0 p-0 max-w-narrow mx-auto flex flex-col gap-px bg-rule">
          {talks.map((t, idx) => (
            <li class="bg-bg">
              <a
                href={`/talks/${t.id}`}
                class="talk-row group relative grid grid-cols-1 md:grid-cols-[80px_1fr_auto] gap-4 md:gap-8 items-start py-8 md:py-10 px-1 md:px-2 no-underline transition-colors hover:bg-surface-soft"
              >
                <!-- Number stamp + year -->
                <div class="hidden md:flex flex-col items-start gap-1 font-mono text-muted">
                  <span class="text-xs font-semibold uppercase tracking-[0.18em]">
                    No. {String(talks.length - idx).padStart(2, '0')}
                  </span>
                  <span class="text-[2.5rem] font-serif font-semibold text-ink leading-none">
                    '{yearStamp(t.data.date)}
                  </span>
                </div>

                <!-- Body -->
                <div class="min-w-0">
                  {t.data.tag && (
                    <p class="inline-block text-[0.7rem] font-bold uppercase tracking-[0.14em] text-accent-ink bg-surface-soft px-2.5 py-1 rounded-full m-0 mb-3">
                      {t.data.tag}
                    </p>
                  )}
                  <h2 class="font-serif font-semibold text-ink text-2xl md:text-3xl tracking-tight leading-tight m-0 mb-2 group-hover:text-accent transition-colors">
                    {t.data.title}
                  </h2>
                  <p class="text-sm text-muted m-0 mb-3">
                    {fmt(t.data.date)}{t.data.venue ? ` · ${t.data.venue}` : ''}
                  </p>
                  <p class="text-body m-0 max-w-prose">
                    {t.data.description}
                  </p>
                </div>

                <!-- CTA arrow + label -->
                <div class="hidden md:flex flex-col items-end gap-2 self-center pr-2">
                  <span class="text-xs font-semibold uppercase tracking-[0.14em] text-muted group-hover:text-ink transition-colors">
                    Open
                  </span>
                  <div class="w-12 h-12 rounded-full border border-rule bg-surface flex items-center justify-center transition-all group-hover:border-ink group-hover:bg-ink group-hover:text-bg">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
                         class="transition-transform group-hover:translate-x-0.5">
                      <line x1="5" y1="12" x2="19" y2="12" />
                      <polyline points="12 5 19 12 12 19" />
                    </svg>
                  </div>
                </div>
              </a>
            </li>
          ))}
        </ol>
      )}
    </Section>

  </div>
</BaseLayout>

<style>
  /* Hairline rule between rows. The gap-px + bg-rule trick gives a
     pixel-perfect divider regardless of border collapse. */
  .talk-row::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 2px;
    background: var(--color-rule-strong);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.5s cubic-bezier(0.2, 0, 0.2, 1);
  }
  .talk-row:hover::before {
    transform: scaleX(1);
  }
</style>
