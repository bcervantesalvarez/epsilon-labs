---
// src/pages/single.astro — the hidden "I'm Single BTW" page.
//
// Not linked from anywhere. Not in the sitemap (filtered in
// astro.config.ts). noindex'd below. The only way in is the
// five-click easter egg on the About page portrait — see about.astro.
import BaseLayout from '@layouts/BaseLayout.astro';
import LandingSection from '@components/LandingSection.astro';
import Button from '@components/Button.astro';
import StatusBanner from '@components/StatusBanner.astro';
import Floaters from '@components/Floaters.astro';

const INSTAGRAM = 'https://www.instagram.com/brianadolfocervantesalvarez';

// Flag emoji don't render on Windows (falls back to "MX US" text),
// so the flags are tiny inline SVGs instead.
const identity = [
  { label: 'Mexican-American', flags: true },
  { label: 'Dual citizen' },
  { label: 'Oregon' },
  { label: 'Data Scientist' },
  { label: 'AI Builder' },
  { label: 'Statistician' },
];

const education = [
  { degree: "Bachelor's", school: 'Linfield University', field: 'Mathematics', when: '',
    color: '#4B0082',
    logo: '/images/schools/linfield.svg', monogram: 'L' },
  { degree: "Master's", school: 'Willamette University', field: 'Data Science', when: '2023',
    color: '#A6093D',
    logo: '/images/schools/willamette.svg', monogram: 'WU' },
  { degree: "Master's", school: 'Oregon State University', field: 'Statistics', when: '2025',
    color: '#DC4405',
    logo: '/images/schools/oregon-state.svg', monogram: 'OSU' },
];

// Editorial index: no icons, just type. Numbers run continuously so
// it reads like a table of contents of how I spend my time.
const hobbyGroupsRaw = [
  { label: 'The regulars', es: 'Las de siempre',
    items: ['Baking', 'Working Out', 'AI & Data Science', 'Video Games', 'Traveling'] },
  { label: 'New this year', es: 'Estrenando',
    items: ['Fishing', 'Wine Tasting', 'Soccer Matches'] },
  { label: 'Nerd interests', es: 'Modo nerd',
    items: ['Star Wars', 'Anime', 'Audiophile', 'PC Building', 'Technology'] },
];
let hobbyIdx = 0;
const hobbyGroups = hobbyGroupsRaw.map((g) => ({
  ...g,
  items: g.items.map((label) => ({ label, n: String(++hobbyIdx).padStart(2, '0') })),
}));

// Famous-dish showcase. Photos hot-link Wikimedia Commons (stable,
// browser-friendly); each card keeps an emoji backdrop so a missing
// image degrades to a handsome placeholder instead of a hole.
type Dish = { name: string; emoji: string; img: string; img2?: string; note: string };
const dishes: Dish[] = [
  { name: 'Pozole', emoji: '🍲',
    img: 'https://commons.wikimedia.org/wiki/Special:FilePath/Pozole_rojo.jpg?width=800',
    note: 'La sopa que cura todo — hasta el mal de amores 🤗' },
  { name: 'Tacos al Pastor', emoji: '🌮',
    img: 'https://commons.wikimedia.org/wiki/Special:FilePath/01_Tacos_al_Pastor.jpg?width=800',
    note: 'El estándar de oro. Con piña, obviamente 🍍' },
  { name: 'Tamales', emoji: '🫔',
    img: 'https://commons.wikimedia.org/wiki/Special:FilePath/Tamales_de_frijol.JPG?width=800',
    note: 'Navidad envuelta en hoja de maíz' },
  { name: 'Mole', emoji: '🍫',
    img: 'https://commons.wikimedia.org/wiki/Special:FilePath/Mole_poblano%2C_M%C3%A9xico.JPG?width=800',
    note: 'Chocolate + chile = la química correcta' },
  { name: 'Enchiladas', emoji: '🌶️',
    img: 'https://commons.wikimedia.org/wiki/Special:FilePath/Enchiladas_mineras.jpg?width=800',
    note: 'Nivel de picante: negociable 😌' },
];
// Local files in /images/dishes/ win; img2 is the hot-linked fallback,
// and the emoji placeholder catches anything that slips past both.
const sweets: Dish[] = [
  { name: 'Cheesecake', emoji: '🍰',
    img: '/images/dishes/cheesecake.jpg',
    img2: 'https://commons.wikimedia.org/wiki/Special:FilePath/Healthy_Strawberry_Cheesecake.jpg?width=800',
    note: 'El clásico que nunca falla — con berries, mejor' },
  { name: 'Brownies', emoji: '🍫',
    img: 'https://commons.wikimedia.org/wiki/Special:FilePath/Chocolatebrownie.JPG?width=800',
    note: 'Fudgy, nunca cakey — hay niveles' },
  { name: 'Lemon Loaf', emoji: '🍋',
    img: '/images/dishes/lemon-loaf.jpg',
    img2: 'https://www.justsotasty.com/wp-content/uploads/2024/02/Lemon-Loaf-2.jpg',
    note: 'Sí, mejor que el de la cafetería ☕' },
  { name: 'Banana Bread', emoji: '🍌',
    img: 'https://commons.wikimedia.org/wiki/Special:FilePath/Banana_bread.jpg?width=800',
    note: 'Todo plátano maduro tiene un destino' },
  { name: 'Stella Rosa', emoji: '🍷',
    img: '/images/dishes/stella-rosa.jpg',
    img2: 'https://commons.wikimedia.org/wiki/Special:FilePath/Glass_of_ros%C3%A9_sparkling_wine_-_Sarah_Stierch.jpg?width=800',
    note: 'Stella Peach junto a la alberca — dulce, burbujeante, perfecta 🥂' },
];

// Screen time — poster-style cards, description does the flirting.
// Artwork resolves per card through a fallback chain (see the poster
// script below): a curated local file in /images/posters/<slug>.* ALWAYS
// wins; otherwise the iTunes Search API (keyless, CORS-open — real
// store posters for nearly everything), then Wikipedia's pageimages
// as a last networked resort. The hue+emoji card stays underneath as
// the instant placeholder, so failures cost nothing.
//   slug — filename in the /images/posters/ drop-zone (see README.txt)
//   tvz — TVmaze show ID (series only): keyless CORS-open API with
//         canonical 2:3 portrait posters, pinned by ID so lookups are
//         deterministic — no fuzzy-search misses or spin-off pollution
//   q/m/c — iTunes search: term, media kind, optional storefront
//   wiki — exact English Wikipedia article title
type Title = {
  title: string; emoji: string; hue: number; note: string;
  slug: string; tvz?: number; q: string; m: 'tvShow' | 'movie'; c?: string; wiki: string;
};
const shows: Title[] = [
  { title: 'The Office', emoji: '📎', hue: 210, note: 'That’s what she said.',
    slug: 'the-office', tvz: 526, q: 'The Office', m: 'tvShow', wiki: 'The Office (American TV series)' },
  { title: 'Parks & Rec', emoji: '🌳', hue: 130, note: 'Treat yo self. I do.',
    slug: 'parks-and-rec', tvz: 174, q: 'Parks and Recreation', m: 'tvShow', wiki: 'Parks and Recreation' },
  { title: 'El Chavo del Ocho', emoji: '🛢️', hue: 45, note: 'Fue sin querer queriendo.',
    slug: 'el-chavo', tvz: 24307, q: 'El Chavo', m: 'tvShow', c: 'mx', wiki: 'El Chavo del Ocho' },
  { title: 'La Familia P. Luche', emoji: '🧸', hue: 300, note: 'En peluche, obviamente.',
    slug: 'p-luche', tvz: 29699, q: 'La Familia P. Luche', m: 'tvShow', c: 'mx', wiki: 'La familia P. Luche' },
  { title: 'The Walking Dead', emoji: '🧟', hue: 90, note: 'I’d survive. Statistically.',
    slug: 'walking-dead', tvz: 73, q: 'The Walking Dead', m: 'tvShow', wiki: 'The Walking Dead (TV series)' },
  { title: 'Breaking Bad', emoji: '⚗️', hue: 160, note: 'Say my name. (Es Brian.)',
    slug: 'breaking-bad', tvz: 169, q: 'Breaking Bad', m: 'tvShow', wiki: 'Breaking Bad' },
  { title: 'Dexter', emoji: '🩸', hue: 355, note: 'Tonight’s the night.',
    slug: 'dexter', tvz: 161, q: 'Dexter', m: 'tvShow', wiki: 'Dexter (TV series)' },
  { title: 'Vincenzo', emoji: '⚖️', hue: 230, note: 'K-drama + abogado de la mafia = cine.',
    slug: 'vincenzo', tvz: 52656, q: 'Vincenzo', m: 'tvShow', wiki: 'Vincenzo (TV series)' },
  { title: 'Attack on Titan', emoji: '🗡️', hue: 20, note: 'Shinzou wo sasageyo.',
    slug: 'attack-on-titan', tvz: 919, q: 'Attack on Titan', m: 'tvShow', wiki: 'Attack on Titan (TV series)' },
  { title: 'Black Clover', emoji: '🍀', hue: 140, note: 'La magia es no rendirse.',
    slug: 'black-clover', tvz: 31396, q: 'Black Clover', m: 'tvShow', wiki: 'Black Clover' },
  { title: 'Stranger Things', emoji: '👾', hue: 358, note: 'Friends don’t lie.',
    slug: 'stranger-things', tvz: 2993, q: 'Stranger Things', m: 'tvShow', wiki: 'Stranger Things' },
];
const movies: Title[] = [
  { title: 'Star Wars I–VI', emoji: '🌌', hue: 250, note: 'The saga as intended — yes, prequels included.',
    slug: 'star-wars', q: 'Star Wars A New Hope', m: 'movie', wiki: 'Star Wars (film)' },
  { title: 'Harry Potter 1–8', emoji: '⚡', hue: 48, note: 'Siempre listo para el maratón completo.',
    slug: 'harry-potter', q: 'Harry Potter and the Sorcerer\'s Stone', m: 'movie', wiki: 'Harry Potter and the Philosopher\'s Stone (film)' },
  { title: 'The Lord of the Rings', emoji: '💍', hue: 105, note: 'Extended editions. Obviamente.',
    slug: 'lotr', q: 'The Lord of the Rings The Fellowship of the Ring', m: 'movie', wiki: 'The Lord of the Rings: The Fellowship of the Ring' },
  { title: 'The Hobbit 1–3', emoji: '🐉', hue: 30, note: 'El cierre del viaje — palomitas obligatorias.',
    slug: 'hobbit', q: 'The Hobbit An Unexpected Journey', m: 'movie', wiki: 'The Hobbit: An Unexpected Journey' },
  { title: 'A Minecraft Movie', emoji: '⛏️', hue: 110, note: 'Bloques + palomitas = plan perfecto.',
    slug: 'minecraft', q: 'A Minecraft Movie', m: 'movie', wiki: 'A Minecraft Movie' },
  { title: 'The Super Mario Bros. Movie', emoji: '🍄', hue: 2, note: 'Let’s-a go. Sin pena.',
    slug: 'super-mario', q: 'The Super Mario Bros. Movie', m: 'movie', wiki: 'The Super Mario Bros. Movie' },
  { title: 'Roma', emoji: '🖤', hue: 220, note: 'Cuarón, blanco y negro, lágrimas garantizadas.',
    slug: 'roma', q: 'Roma Alfonso Cuarón', m: 'movie', wiki: 'Roma (2018 film)' },
  { title: 'Instructions Not Included', emoji: '🧭', hue: 35, note: 'Derbez: reír y llorar en la misma escena.',
    slug: 'instructions', q: 'Instructions Not Included', m: 'movie', wiki: 'Instructions Not Included' },
];

// The story, in order — how I picture it unfolding.
const goals = [
  { emoji: '🌱', label: 'Shared growth',
    story: 'It starts simple: two people making each other better. Your goals become part of my planning, mine become part of yours.' },
  { emoji: '🥾', label: 'Local adventures',
    story: 'Weekends that feel like little trips — coffee crawls, hikes, mercados, bailes, jaripeos, and live sports whenever we can (fútbol first, siempre ⚽).' },
  { emoji: '🌍', label: 'Travel together',
    story: 'Then bigger maps: road trips up the coast, México to see family, Europe again — this time with someone to share the window seat.' },
  { emoji: '💞', label: 'Long-term relationship',
    story: 'Built slow and solid — the kind where the paperwork is boring because the trust was settled years earlier.' },
  { emoji: '💍', label: 'Marriage',
    story: 'When it stops being a question. No rushing milestones — but yes, this is where I want the road to lead.' },
  { emoji: '👶', label: '1–2 kids',
    story: 'A little familia of our own — raised bilingual, well-fed (see the food section), and thoroughly loved.' },
];

const lookingFor = [
  'Kind', 'Curious', 'Emotionally mature', 'Ambitious', 'Communicative',
  'Hygienic', 'Independent', 'Looking for something serious', 'Comfortable growing together',
];

const construction = [
  { t: "Sometimes I'm too organized.",
    d: 'I have my mini-OCDs: once I commit to organizing something, it has to be organized well — labels, categories, the whole system — and a full day can quietly disappear into it. The closet has never looked better, though.' },
  { t: 'I sit on small annoyances longer than I should.',
    d: "If something tiny bothers me, I'll sometimes wait too long to say it out loud because it feels too small to bring up. I'm working on saying the small things early so they never become big things." },
  { t: 'I help… a lot.',
    d: "My default is to fix, support, and take things off your plate — and sometimes that much help can feel overwhelming instead of loving. Please tell me if it happens; I'd rather adjust than smother." },
  { t: "I'm still finding my spiritual side.",
    d: "I want to become more spiritually reflective — more moments of gratitude and quiet — and I'm honestly early in that journey." },
  { t: 'Professional homebody (some weeks).',
    d: 'Staying home is significantly cheaper, and some weeks I lean into that a little too hard. The fix is easy: give me a reason to go out. Be the reason 😉' },
  { t: 'I proudly live with my parents.',
    d: "Not a flaw to me, but said plainly: I live with my familia and I'm proud of it. One day I'd love a place of my own — once I know they're set and in a good spot. Family first, always." },
];
---
<BaseLayout title="I'm Single BTW" description="A hidden page for the curious.">
  <meta slot="head" name="robots" content="noindex,nofollow" />

  {/* data-pagefind-ignore="all": the site search must never surface
      the secret — this page stays out of the Pagefind index entirely */}
  <div data-pagefind-ignore="all" class="romance">

  <!-- ── Hero ─────────────────────────────────────────────────── -->
  <section class="tone-dark grain hero-mesh relative overflow-hidden pt-24 pb-20 lg:pt-28 lg:pb-24" aria-labelledby="single-hero-title">
    <div class="romance-orb-layer absolute inset-0" aria-hidden="true">
      <div class="romance-orb romance-orb-a"></div>
      <div class="romance-orb romance-orb-b"></div>
    </div>
    <div class="max-w-wrap mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-[auto_1fr] gap-10 lg:gap-14 items-center">
        <div class="relative justify-self-center" id="single-photo-wrap">
          <img
            id="single-photo"
            src="/images/profile.jpg"
            alt="Brian, smiling"
            loading="eager"
            width="288"
            height="288"
            draggable="false"
            class="romance-photo w-52 h-52 lg:w-72 lg:h-72 rounded-3xl object-cover [object-position:50%_25%] border border-rule-strong animate-el-fade select-none cursor-pointer"
          />
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted m-0 mb-4 animate-el-rise [animation-delay:120ms]">
            You found the hidden page 🎉 · Bienvenid@
          </p>
          <h1 id="single-hero-title" class="font-serif font-semibold text-ink text-display m-0 mb-4 animate-el-rise [animation-delay:220ms]">
            Brian
          </h1>
          <p class="text-lede text-ink font-semibold m-0 mb-1 animate-el-rise [animation-delay:300ms]">
            Status: Single <span class="heartbeat" aria-hidden="true">❤️</span> · <span id="single-age">—</span> years old
          </p>
          <p class="text-sm text-muted italic m-0 mb-6 animate-el-rise [animation-delay:340ms]">
            (This page will immediately be removed the day this becomes untrue.)
          </p>
          <ul class="flex flex-wrap gap-2 list-none m-0 p-0 mb-7 animate-el-rise [animation-delay:400ms]" aria-label="About me at a glance">
            {identity.map((t) => (
              <li class="inline-flex items-center gap-1.5 text-[0.72rem] font-bold uppercase tracking-[0.13em] text-accent-ink bg-surface-soft border border-rule px-3 py-1.5 rounded-full m-0">
                {t.label}
                {t.flags && (
                  <span class="inline-flex items-center gap-1" aria-label="Mexico and United States">
                    <svg class="miniflag" viewBox="0 0 3 2" aria-hidden="true"><rect width="1" height="2" fill="#006341"/><rect x="1" width="1" height="2" fill="#fff"/><rect x="2" width="1" height="2" fill="#C8102E"/><circle cx="1.5" cy="1" r="0.3" fill="#8C6A2F"/></svg>
                    <svg class="miniflag" viewBox="0 0 3 2" aria-hidden="true"><rect width="3" height="2" fill="#B22234"/><g fill="#fff"><rect y="0.31" width="3" height="0.22"/><rect y="0.77" width="3" height="0.22"/><rect y="1.23" width="3" height="0.22"/><rect y="1.69" width="3" height="0.22"/></g><rect width="1.25" height="1" fill="#3C3B6E"/></svg>
                  </span>
                )}
              </li>
            ))}
          </ul>
          <p class="text-body max-w-[56ch] m-0 animate-el-rise [animation-delay:460ms]">
            I'm a naturally curious person who enjoys building things, learning
            constantly, and finding joy in both quiet evenings at home and
            exploring somewhere new. I'm looking for someone to build a
            meaningful, long-term life with.
          </p>
          <p class="text-sm text-muted italic m-0 mt-3 animate-el-rise [animation-delay:520ms]">
            Y sí, también hablo español — pregúntame lo que quieras 😉
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Education ────────────────────────────────────────────── -->
  <LandingSection
    id="single-education"
    n="01"
    eyebrow="Receipts · Los recibos"
    title="Education."
  >
    <Floaters glyphs={['🎓', '🎓', '🎓', '🎓', '🎓']} variant="toss" />
    <ol class="grid grid-cols-1 md:grid-cols-3 gap-6 list-none m-0 p-0" data-stagger>
      {education.map((e) => (
        <li
          class="edu-card group relative overflow-hidden bg-surface border border-rule rounded-2xl m-0 flex flex-col transition-all duration-300"
          style={`--school-color: ${e.color};`}
        >
          <div class="edu-band relative overflow-hidden p-6 md:p-7 text-white">
            <span class="edu-watermark edu-monogram" aria-hidden="true">{e.monogram}</span>
            <img
              class="edu-watermark"
              src={e.logo}
              alt=""
              aria-hidden="true"
              loading="lazy"
              decoding="async"
              onload="this.closest('.edu-band')?.querySelector('.edu-monogram')?.remove()"
              onerror="this.remove()"
            />
            <p class="relative text-[0.7rem] font-bold uppercase tracking-[0.16em] opacity-85 m-0 mb-2">
              {e.degree}{e.when && ` · ${e.when}`}
            </p>
            <h3 class="relative font-serif font-semibold text-2xl tracking-tight leading-tight m-0 text-white">{e.school}</h3>
          </div>
          <div class="p-6 md:p-7 flex flex-col gap-5 flex-1">
            <p class="text-body text-sm font-semibold m-0 mt-auto">{e.field}</p>
          </div>
        </li>
      ))}
    </ol>

    {/* The next degree: wide Ph.D. goal banner in OSU colors */}
    <aside
      class="edu-card group relative overflow-hidden bg-surface border border-rule rounded-2xl mt-6 grid grid-cols-1 md:grid-cols-[1.15fr_1fr] transition-all duration-300"
      style="--school-color: #DC4405;"
      aria-labelledby="phd-goal-title"
    >
      <div class="edu-band relative overflow-hidden p-7 md:p-9 text-white">
        <span class="edu-watermark edu-monogram" aria-hidden="true">PhD</span>
        <p class="relative text-[0.7rem] font-bold uppercase tracking-[0.16em] opacity-85 m-0 mb-2">
          The one that's coming · La próxima meta 🎓
        </p>
        <h3 id="phd-goal-title" class="relative font-serif font-semibold text-2xl md:text-3xl tracking-tight leading-tight m-0 text-white">
          Ph.D. in Artificial Intelligence
        </h3>
        <p class="relative text-sm font-medium opacity-90 m-0 mt-4">
          Target start 2030–2032 · defended before 2035
        </p>
      </div>
      <div class="p-7 md:p-9 flex flex-col justify-center">
        <p class="text-body text-sm leading-relaxed m-0">
          The plan is set: keep shipping AI systems in production now, then
          formalize it with research. Likely home: Oregon State — I already
          look good in Beaver orange, and they know me.
        </p>
      </div>
    </aside>
  </LandingSection>

  <!-- ── Current chapter ──────────────────────────────────────── -->
  <LandingSection
    id="single-now"
    n="02"
    eyebrow="Life right now · La vida hoy"
    title="Current chapter."
    tone="tint"
  >
    <StatusBanner
      href="https://www.oregon.gov/ode/"
      org="Oregon Department of Education"
      role="Business Intelligence Analyst · Since Dec 8, 2025 — yes, this is the day job"
    />
    <div class="max-w-prose">
      <p class="text-body m-0 mb-4">
        I have a stable career that I genuinely enjoy, and my biggest
        financial priority right now is paying off my student loans — most
        of my disposable income is going toward becoming debt-free. I'm
        financially responsible and intentionally investing in my future,
        and honestly, it feels great.
      </p>
      <p class="text-body m-0">
        Because of that, I'm far more interested in meaningful experiences
        than expensive dates: coffee shops, cooking together, local
        adventures, long walks, museums, game nights, road trips, and
        simply spending quality time together. The best parts of getting to
        know someone were never behind a paywall anyway.
      </p>
    </div>

    <div class="max-w-prose mt-8">
      <p class="text-body m-0 mb-4">
        For the curious (I know you're doing the math): the State pays me
        a comfortable, stable salary in the healthy five figures — and once
        you count the benefits package, worth roughly another quarter on
        top, the total quietly crosses six. Yes, I count the benefits.
        I'm a statistician; counting is the whole job.
      </p>
      <p class="text-body m-0 mb-4">
        Government pace is a slower ride than the private sector — that's
        the honest trade, and the stability is exactly the point. I lean
        toward remote-friendly work, and the trajectory only points up
        from here.
      </p>
      <p class="text-lede text-ink font-serif m-0">
        Financial stability is my ultimate goal.
        <span class="text-muted text-base italic"> La estabilidad primero — lo demás llega solito 😌</span>
      </p>
    </div>
  </LandingSection>

  <!-- ── Hobbies ──────────────────────────────────────────────── -->
  <LandingSection
    id="single-hobbies"
    n="03"
    eyebrow="How I spend my time"
    title="Hobbies."
  >
    <div class="flex flex-col gap-12">
      {hobbyGroups.map((g) => (
        <div>
          <h3 class="inline-flex items-baseline gap-3 text-sm font-bold uppercase tracking-[0.14em] text-ink bg-surface border border-rule rounded-full px-5 py-2 m-0 mb-7">
            {g.label}
            <span class="text-muted normal-case tracking-normal font-medium italic">· {g.es}</span>
          </h3>
          <ul class="hobby-index list-none m-0 p-0" data-stagger>
            {g.items.map((t) => (
              <li class="hobby-item m-0">
                <span class="hobby-num" aria-hidden="true">{t.n}</span>
                <span class="hobby-label font-serif font-semibold tracking-tight">{t.label}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </LandingSection>

  <!-- ── Favorites ────────────────────────────────────────────── -->
  <LandingSection
    id="single-favorites"
    n="04"
    eyebrow="The important data · La comida es amor"
    title="Favorite things."
    tone="tint"
  >
    <Floaters glyphs={['🌮', '🍰', '🍷', '🫔', '🍫']} variant="drift" />

    {/* Restaurant-style dish showcase: swipe or use the arrows */}
    <div class="dish-rail-wrap relative mb-12">
      <ul class="dish-rail list-none m-0 p-0" tabindex="0" aria-label="My favorite Mexican dishes">
        {dishes.map((d) => (
          <li class="dish-card group m-0">
            <div class="dish-media relative overflow-hidden">
              <span class="dish-emoji" aria-hidden="true">{d.emoji}</span>
              <img
                src={d.img}
                data-img2={d.img2}
                alt={d.name}
