---
// src/pages/single.astro — the hidden "I'm Single BTW" page.
//
// Not linked from anywhere. Not in the sitemap (filtered in
// astro.config.ts). noindex'd below. The only way in is the
// five-click easter egg on the About page portrait — see about.astro.
import BaseLayout from '@layouts/BaseLayout.astro';
import LandingSection from '@components/LandingSection.astro';
import Button from '@components/Button.astro';

const INSTAGRAM = 'https://www.instagram.com/brianadolfocervantesalvarez';

const identity = ['Hispanic (Mexican)', 'Oregon', 'Data Scientist', 'AI Builder', 'Statistician'];

const education = [
  { degree: "Bachelor's", school: 'Linfield University', field: 'Mathematics', when: '',
    color: '#4B0082',
    logo: 'https://thelinfieldreview.com/wp-content/uploads/2020/11/Linflogo-copy-900x900.jpg' },
  { degree: "Master's", school: 'Willamette University', field: 'Data Science', when: '2023',
    color: '#A6093D',
    logo: 'https://abound.college/mba/wp-content/uploads/sites/4/2019/01/willamette-university-logo.png' },
  { degree: "Master's", school: 'Oregon State University', field: 'Statistics', when: '2025',
    color: '#DC4405',
    logo: 'https://commons.wikimedia.org/wiki/Special:FilePath/Oregon_State_University_wordmark.svg' },
];

const hobbies = {
  regular: [
    { emoji: '🥐', label: 'Baking' },
    { emoji: '💪', label: 'Working Out' },
    { emoji: '🤖', label: 'AI & Data Science' },
    { emoji: '🎮', label: 'Video Games' },
    { emoji: '✈️', label: 'Traveling' },
  ],
  fresh: [
    { emoji: '🎣', label: 'Fishing' },
    { emoji: '🍷', label: 'Wine Tasting' },
    { emoji: '⚽', label: 'Soccer Matches' },
  ],
  nerd: [
    { emoji: '🌌', label: 'Star Wars' },
    { emoji: '🎌', label: 'Anime' },
    { emoji: '🎧', label: 'Audiophile' },
    { emoji: '🖥️', label: 'PC Building' },
    { emoji: '📱', label: 'Technology' },
  ],
};

const mexicanFoods = ['Pozole', 'Tamales', 'Mole', 'Enchiladas', 'Tacos al Pastor'];
const desserts = ['Cheesecake', 'Brownies', 'Lemon Loaf', 'Banana Bread'];

const goals = [
  { emoji: '👶', label: 'One child' },
  { emoji: '💞', label: 'Long-term relationship' },
  { emoji: '🌍', label: 'Travel together' },
  { emoji: '🥾', label: 'Local adventures' },
  { emoji: '🛫', label: 'International travel' },
  { emoji: '🌱', label: 'Shared growth' },
];

const lookingFor = [
  'Kind', 'Curious', 'Emotionally mature', 'Ambitious', 'Communicative',
  'Hygienic', 'Independent', 'Looking for something serious', 'Comfortable growing together',
];

const construction = [
  "Sometimes I'm too organized.",
  'I occasionally avoid addressing small annoyances longer than I should.',
  'I have a tendency to help so much that it can become overwhelming — please tell me if that happens.',
  "I'm trying to become more spiritually reflective.",
  'Some weeks I accidentally become a professional homebody because staying home is significantly cheaper.',
];
---
<BaseLayout title="I'm Single BTW" description="A hidden page for the curious.">
  <meta slot="head" name="robots" content="noindex,nofollow" />

  {/* data-pagefind-ignore="all": the site search must never surface
      the secret — this page stays out of the Pagefind index entirely */}
  <div data-pagefind-ignore="all" class="romance">

  <!-- ── Hero ─────────────────────────────────────────────────── -->
  <section class="tone-dark grain hero-mesh relative overflow-hidden pt-24 pb-20 lg:pt-28 lg:pb-24" aria-labelledby="single-hero-title">
    <div class="romance-orb-layer absolute inset-0" aria-hidden="true">
      <div class="romance-orb romance-orb-a"></div>
      <div class="romance-orb romance-orb-b"></div>
    </div>
    <div class="max-w-wrap mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-[auto_1fr] gap-10 lg:gap-14 items-center">
        <div class="relative justify-self-center" id="single-photo-wrap">
          <img
            id="single-photo"
            src="/images/profile.jpg"
            alt="Brian, smiling"
            loading="eager"
            width="288"
            height="288"
            draggable="false"
            class="romance-photo w-52 h-52 lg:w-72 lg:h-72 rounded-3xl object-cover [object-position:50%_25%] border border-rule-strong animate-el-fade select-none cursor-pointer"
          />
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted m-0 mb-4 animate-el-rise [animation-delay:120ms]">
            You found the hidden page 🎉
          </p>
          <h1 id="single-hero-title" class="font-serif font-semibold text-ink text-display m-0 mb-4 animate-el-rise [animation-delay:220ms]">
            Brian
          </h1>
          <p class="text-lede text-ink font-semibold m-0 mb-1 animate-el-rise [animation-delay:300ms]">
            Status: Single <span class="heartbeat" aria-hidden="true">❤️</span> · <span id="single-age">—</span> years old
          </p>
          <p class="text-sm text-muted italic m-0 mb-6 animate-el-rise [animation-delay:340ms]">
            (This page will immediately be removed the day this becomes untrue.)
          </p>
          <ul class="flex flex-wrap gap-2 list-none m-0 p-0 mb-7 animate-el-rise [animation-delay:400ms]" aria-label="About me at a glance">
            {identity.map((t) => (
              <li class="text-[0.72rem] font-bold uppercase tracking-[0.13em] text-accent-ink bg-surface-soft border border-rule px-3 py-1.5 rounded-full m-0">
                {t}
              </li>
            ))}
          </ul>
          <p class="text-body max-w-[56ch] m-0 animate-el-rise [animation-delay:460ms]">
            I'm a naturally curious person who enjoys building things, learning
            constantly, and finding joy in both quiet evenings at home and
            exploring somewhere new. I'm looking for someone to build a
            meaningful, long-term life with.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Education ────────────────────────────────────────────── -->
  <LandingSection
    id="single-education"
    n="01"
    eyebrow="Receipts"
    title="Education."
  >
    <ol class="grid grid-cols-1 md:grid-cols-3 gap-6 list-none m-0 p-0" data-stagger>
      {education.map((e) => (
        <li
          class="edu-card group relative overflow-hidden bg-surface border border-rule rounded-2xl m-0 flex flex-col transition-all duration-300"
          style={`--school-color: ${e.color};`}
        >
          <div class="edu-band relative overflow-hidden p-6 md:p-7 text-white">
            <img
              class="edu-watermark"
              src={e.logo}
              alt=""
              aria-hidden="true"
              loading="lazy"
              decoding="async"
              onerror="this.remove()"
            />
            <p class="relative text-[0.7rem] font-bold uppercase tracking-[0.16em] opacity-85 m-0 mb-2">
              {e.degree}{e.when && ` · ${e.when}`}
            </p>
            <h3 class="relative font-serif font-semibold text-2xl tracking-tight leading-tight m-0 text-white">{e.school}</h3>
          </div>
          <div class="p-6 md:p-7 flex flex-col gap-5 flex-1">
            <p class="text-body text-sm font-semibold m-0 mt-auto">{e.field}</p>
          </div>
        </li>
      ))}
    </ol>
  </LandingSection>

  <!-- ── Current chapter ──────────────────────────────────────── -->
  <LandingSection
    id="single-now"
    n="02"
    eyebrow="Life right now"
    title="Current chapter."
    tone="tint"
  >
    <div class="max-w-prose">
      <p class="text-body m-0 mb-4">
        I have a stable career that I genuinely enjoy, and my biggest
        financial priority right now is paying off my student loans — most
        of my disposable income is going toward becoming debt-free. I'm
        financially responsible and intentionally investing in my future,
        and honestly, it feels great.
      </p>
      <p class="text-body m-0">
        Because of that, I'm far more interested in meaningful experiences
        than expensive dates: coffee shops, cooking together, local
        adventures, long walks, museums, game nights, road trips, and
        simply spending quality time together. The best parts of getting to
        know someone were never behind a paywall anyway.
      </p>
    </div>
  </LandingSection>

  <!-- ── Hobbies ──────────────────────────────────────────────── -->
  <LandingSection
    id="single-hobbies"
    n="03"
    eyebrow="How I spend my time"
    title="Hobbies."
  >
    <div class="flex flex-col gap-10">
      <div>
        <h3 class="text-sm font-bold uppercase tracking-[0.14em] text-ink m-0 mb-5">The regulars</h3>
        <ul class="card-flow list-none m-0 p-0" data-stagger>
          {hobbies.regular.map((h) => (
            <li class="bg-surface border border-rule rounded-2xl px-6 py-5 m-0 flex items-center gap-4 transition-all duration-300 hover:-translate-y-0.5 hover:border-rule-strong">
              <span class="text-3xl" aria-hidden="true">{h.emoji}</span>
              <span class="font-semibold text-ink">{h.label}</span>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-bold uppercase tracking-[0.14em] text-ink m-0 mb-5">New this year</h3>
        <ul class="card-flow list-none m-0 p-0" data-stagger>
          {hobbies.fresh.map((h) => (
            <li class="bg-surface border border-rule rounded-2xl px-6 py-5 m-0 flex items-center gap-4 transition-all duration-300 hover:-translate-y-0.5 hover:border-rule-strong">
              <span class="text-3xl" aria-hidden="true">{h.emoji}</span>
              <span class="font-semibold text-ink">{h.label}</span>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-bold uppercase tracking-[0.14em] text-ink m-0 mb-5">Nerd interests</h3>
        <ul class="card-flow list-none m-0 p-0" data-stagger>
          {hobbies.nerd.map((h) => (
            <li class="bg-surface border border-rule rounded-2xl px-6 py-5 m-0 flex items-center gap-4 transition-all duration-300 hover:-translate-y-0.5 hover:border-rule-strong">
              <span class="text-3xl" aria-hidden="true">{h.emoji}</span>
              <span class="font-semibold text-ink">{h.label}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </LandingSection>

  <!-- ── Favorites ────────────────────────────────────────────── -->
  <LandingSection
    id="single-favorites"
    n="04"
    eyebrow="The important data"
    title="Favorite things."
    tone="tint"
  >
    <div class="card-flow" data-stagger>
      <div class="bg-surface border border-rule rounded-2xl p-7">
        <h3 class="text-sm font-bold uppercase tracking-[0.14em] text-ink m-0 mb-4">🍗 Food, generally</h3>
        <p class="text-body text-sm m-0">
          Anything involving chicken — except extremely greasy fried
          chicken. A man needs standards.
        </p>
      </div>
      <div class="bg-surface border border-rule rounded-2xl p-7">
        <h3 class="text-sm font-bold uppercase tracking-[0.14em] text-ink m-0 mb-4">🇲🇽 Mexican favorites</h3>
        <ul class="list-none m-0 p-0 flex flex-wrap gap-2">
          {mexicanFoods.map((f) => (
            <li class="text-sm font-semibold text-ink bg-surface-soft border border-rule px-3 py-1.5 rounded-full m-0">{f}</li>
          ))}
        </ul>
      </div>
      <div class="bg-surface border border-rule rounded-2xl p-7">
        <h3 class="text-sm font-bold uppercase tracking-[0.14em] text-ink m-0 mb-4">🍰 Desserts</h3>
        <ul class="list-none m-0 p-0 flex flex-wrap gap-2">
          {desserts.map((f) => (
            <li class="text-sm font-semibold text-ink bg-surface-soft border border-rule px-3 py-1.5 rounded-full m-0">{f}</li>
          ))}
        </ul>
      </div>
      <div class="bg-surface border border-rule rounded-2xl p-7">
        <h3 class="text-sm font-bold uppercase tracking-[0.14em] text-ink m-0 mb-4">🍷 Favorite wine</h3>
        <p class="text-body text-sm m-0">
          Stella Rosa. Yes, I know. No, I won't be taking questions.
        </p>
      </div>
    </div>
  </LandingSection>

  <!-- ── Instagram ────────────────────────────────────────────── -->
  <LandingSection
    id="single-gram"
    n="05"
    eyebrow="Proof of life"
    title="From my Instagram."
    tone="dark"
  >
    <div id="ig-gallery" class="hidden grid-cols-2 md:grid-cols-4 gap-4 mb-8"></div>
    <div id="ig-fallback" class="bg-surface border border-rule rounded-2xl px-8 py-12 text-center">
      <p class="text-lede text-ink m-0 mb-2">Looks like Instagram is being stubborn today.</p>
      <p class="text-sm text-muted m-0 mb-7">
        Europe trips, educational milestones, and other questionable
        adventures live over there.
      </p>
      <Button href={INSTAGRAM} target="_blank" rel="noreferrer">View my Instagram →</Button>
    </div>
  </LandingSection>

  <!-- ── Relationship goals ───────────────────────────────────── -->
  <LandingSection
    id="single-goals"
    n="06"
    eyebrow="The long game"
    title="Relationship goals."
  >
    <ul class="card-flow list-none m-0 p-0 mb-8" data-stagger>
      {goals.map((g) => (
        <li class="bg-surface border border-rule rounded-2xl px-6 py-5 m-0 flex items-center gap-4 transition-all duration-300 hover:-translate-y-0.5 hover:border-rule-strong">
          <span class="text-3xl" aria-hidden="true">{g.emoji}</span>
          <span class="font-semibold text-ink">{g.label}</span>
        </li>
      ))}
    </ul>
    <div class="card-flow">
      <div class="bg-surface-soft border border-rule rounded-2xl p-7">
        <h3 class="text-sm font-bold uppercase tracking-[0.14em] text-ink m-0 mb-3">⛪ Religion</h3>
        <p class="text-body text-sm m-0">
          Culturally Catholic, practically agnostic. Open-minded and
          respectful either way.
        </p>
      </div>
      <div class="bg-surface-soft border border-rule rounded-2xl p-7">
        <h3 class="text-sm font-bold uppercase tracking-[0.14em] text-ink m-0 mb-3">🐈 Pets</h3>
        <p class="text-body text-sm m-0">
          Love animals. If choosing one: cats. Hard maximum of two —
          this is a household, not a sanctuary.
        </p>
      </div>
      <div class="bg-surface-soft border border-rule rounded-2xl p-7">
        <h3 class="text-sm font-bold uppercase tracking-[0.14em] text-ink m-0 mb-3">💬 Love languages</h3>
        <p class="text-body text-sm m-0">
          ❤️ Acts of Service · 🤝 Physical Touch
        </p>
      </div>
    </div>

    <aside class="mt-8 bg-surface border-l-4 border-accent border border-rule rounded-2xl px-7 py-6" aria-label="Random fact">
      <p class="text-body m-0">
        <strong class="text-ink">Random fact:</strong> believe it or not, my
        longest relationship lasted three months... in middle school. So
        yes, we're setting a very achievable record here.
      </p>
    </aside>
  </LandingSection>

  <!-- ── Looking for ──────────────────────────────────────────── -->
  <LandingSection
    id="single-looking"
    n="07"
    eyebrow="The good stuff"
    title="What I'm looking for."
    tone="tint"
  >
    <div class="max-w-prose mb-8">
      <p class="text-body m-0">
        Someone I genuinely like being around — kind by default, curious
        about the world, emotionally mature when things get real, ambitious
        about their own life, and communicative enough that neither of us
        ever has to guess. Someone who takes care of themselves, stands on
        their own, wants something serious, and is comfortable with the
        idea that we'd both keep growing.
      </p>
    </div>
    <ul class="flex flex-wrap gap-2 list-none m-0 p-0" aria-label="Qualities that matter to me">
      {lookingFor.map((q) => (
        <li class="text-sm font-semibold text-ink bg-surface border border-rule px-4 py-2 rounded-full m-0">{q}</li>
      ))}
    </ul>
  </LandingSection>

  <!-- ── Compatibility ────────────────────────────────────────── -->
  <LandingSection
    id="single-compat"
    n="08"
    eyebrow="Honest calibration"
    title="We'd probably be compatible if..."
  >
    <div class="max-w-prose">
      <p class="text-body m-0 mb-4">
        You're not highly religious, you have goals and ambitions of your
        own, and you communicate consistently — disappearing for days is
        the one pattern I can't build anything on. You don't smoke or use
        recreational drugs, and you value personal hygiene the way I do.
      </p>
      <p class="text-body m-0 mb-4">
        You're interested in building a long-term partnership rather than
        rushing milestones: I don't see marriage within the first five
        years of dating, and I wouldn't want children before marriage. At
        this stage of my life, I'm generally not looking to date someone
        who already has children.
      </p>
      <p class="text-body m-0">
        On politics: shared core values and respect for individual rights
        matter to me. I'm an Progressive Independent + compatibility on the big
        life questions is the thing worth checking.
      </p>
    </div>
  </LandingSection>

  <!-- ── Bonus points ─────────────────────────────────────────── -->
  <LandingSection
    id="single-bonus"
    n="09"
    eyebrow="Nice-to-haves, not requirements"
    title="Bonus points."
    tone="tint"
  >
    <div class="max-w-prose mb-8">
      <p class="text-body m-0 mb-4">
        None of these are expectations — but if you're financially
        responsible, understand budgeting, keep a savings mindset, or get
        genuinely excited about investing, CDs, and retirement planning,
        we'll have plenty to talk about.
      </p>
      <p class="text-body m-0 mb-4">
        Since I'm aggressively paying off student loans, I'm much happier
        with homemade dinners, coffee dates, bookstores, hiking, museums,
        and weekend adventures than expensive gifts or luxury restaurants.
      </p>
      <p class="text-body m-0">
        On alcohol: I'm perfectly happy enjoying wine or cocktails
        occasionally, but I don't want it to become the centerpiece of
        every outing.
      </p>
    </div>
  </LandingSection>

  <!-- ── Under construction ───────────────────────────────────── -->
  <LandingSection
    id="single-construction"
    n="10"
    eyebrow="Full disclosure"
    title="Still under construction 🚧"
  >
    <ul class="max-w-prose list-none m-0 p-0 flex flex-col gap-4" data-stagger>
      {construction.map((c) => (
        <li class="bg-surface border border-rule rounded-xl px-6 py-4 m-0 text-body text-sm">
          {c}
        </li>
      ))}
    </ul>
    <p class="text-lede text-ink font-serif max-w-prose mt-8 m-0">
      Personal growth never really ends, and I think that's a good thing.
    </p>
  </LandingSection>

  <!-- ── Final CTA ────────────────────────────────────────────── -->
  <LandingSection
    id="single-cta"
    n="11"
    eyebrow="If you've made it this far..."
    title="Maybe that's a sign."
    tone="dark"
  >
    <div class="max-w-prose mb-9">
      <p class="text-body m-0 mb-3">
        First, congratulations — you found the secret page.
      </p>
      <p class="text-body m-0">
        Second, maybe that's a sign you're exactly the kind of curious
        person I'd enjoy getting to know. If you'd like to say hello,
        Instagram is probably the easiest way to reach me.
      </p>
    </div>
    <div class="flex flex-wrap gap-3">
      <Button href={INSTAGRAM} target="_blank" rel="noreferrer">📷 Instagram</Button>
      <Button href="mailto:briancervantesalvarez@gmail.com" variant="ghost">💬 Send a Message</Button>
    </div>
  </LandingSection>

  </div>
</BaseLayout>

<style>
  /* Education mini-banners: the About page's SchoolBanner language in
     card form — solid school-color band, diagonal sheen sweep on
     hover, colored lift shadow. */
  .edu-band {
    background-color: var(--school-color);
    background-image: linear-gradient(
      135deg,
      var(--school-color) 0%,
      color-mix(in srgb, var(--school-color) 80%, #000 5%) 100%
    );
    isolation: isolate;
  }
  .edu-band::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      120deg,
      transparent 40%,
      rgb(255 255 255 / 0.22) 50%,
      transparent 60%
    );
    transform: translateX(-100%);
    transition: transform 0.7s cubic-bezier(0.2, 0, 0.2, 1);
    pointer-events: none;
  }
  .edu-card:hover .edu-band::after {
    transform: translateX(100%);
  }

  /* Logo watermark: large ghost anchored right, fading into the band
     toward the text. soft-light melts white JPG backgrounds and
     transparent PNGs alike into the school color. */
  .edu-watermark {
    position: absolute;
    top: 50%;
    right: -8%;
    transform: translateY(-50%);
    height: 160%;
    aspect-ratio: 1 / 1;
    object-fit: contain;
    mix-blend-mode: soft-light;
    opacity: 0.9;
    pointer-events: none;
    user-select: none;
    mask-image: linear-gradient(to left, rgb(0 0 0 / 0.95) 30%, transparent 85%);
    -webkit-mask-image: linear-gradient(to left, rgb(0 0 0 / 0.95) 30%, transparent 85%);
    transition: opacity 0.4s ease, transform 0.6s cubic-bezier(0.2, 0, 0.2, 1);
  }
  .edu-card:hover .edu-watermark {
    opacity: 1;
    transform: translateY(-50%) scale(1.06);
  }
  @media (prefers-reduced-motion: reduce) {
    .edu-card:hover .edu-watermark { transform: translateY(-50%); }
  }
  .edu-card:hover {
    transform: translateY(-4px);
    border-color: var(--school-color);
    box-shadow: 0 26px 44px -28px color-mix(in srgb, var(--school-color) 55%, transparent);
  }
  @media (prefers-reduced-motion: reduce) {
    .edu-band::after { transition: none; }
    .edu-card:hover { transform: none; }
  }
</style>

<style is:global>
  /* ── Romance identity — this page only ─────────────────────────
     A rose accent replaces the site blue, and the motion goes a
     step softer and more alive than the main site: drifting gradient
     orbs, a gently bobbing portrait, a heartbeat, wiggling emoji.
     Everything collapses to stillness under reduced motion. */
  .romance {
    --color-accent: rgb(178 58 98);
    --color-accent-ink: rgb(143 41 80);
  }
  .romance .tone-dark {
    --color-accent: rgb(238 143 174);
    --color-accent-ink: rgb(244 185 204);
  }

  /* Drifting hero orbs (rose + amber pools behind the content) */
  .romance-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(64px);
    pointer-events: none;
  }
  .romance-orb-a {
    width: clamp(240px, 46vw, 520px);
    height: clamp(240px, 46vw, 520px);
    top: -14%;
    right: -8%;
    background: radial-gradient(circle, rgb(238 143 174 / 0.42), transparent 70%);
    animation: orb-drift-a 18s ease-in-out infinite alternate;
  }
  .romance-orb-b {
    width: clamp(200px, 38vw, 440px);
    height: clamp(200px, 38vw, 440px);
    bottom: -18%;
    left: -10%;
    background: radial-gradient(circle, rgb(225 160 63 / 0.30), transparent 70%);
    animation: orb-drift-b 24s ease-in-out infinite alternate;
  }
  @keyframes orb-drift-a {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(-9%, 14%) scale(1.18); }
  }
  @keyframes orb-drift-b {
    from { transform: translate(0, 0) scale(1.1); }
    to   { transform: translate(12%, -10%) scale(0.95); }
  }

  /* Portrait: rose ring + slow bob */
  .romance-photo {
    box-shadow:
      0 0 0 8px rgb(238 143 174 / 0.25),
      0 34px 70px -34px rgb(0 0 0 / 0.65);
    animation: photo-bob 7s ease-in-out infinite;
  }
  @keyframes photo-bob {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50%      { transform: translateY(-9px) rotate(-1.2deg); }
  }

  /* Heartbeat: a double-thump, like the real thing */
  .heartbeat {
    display: inline-block;
    transform-origin: center;
    animation: heartbeat 1.8s ease-in-out infinite;
  }
  @keyframes heartbeat {
    0%, 48%, 100% { transform: scale(1); }
    12%           { transform: scale(1.25); }
    24%           { transform: scale(1); }
    36%           { transform: scale(1.18); }
  }

  /* Emoji wiggle on card hover */
  .romance .card-flow li:hover > span:first-child {
    animation: emo-wiggle 0.6s ease;
  }
  @keyframes emo-wiggle {
    0%, 100% { transform: rotate(0); }
    25%      { transform: rotate(-12deg) scale(1.18); }
    60%      { transform: rotate(9deg); }
  }

  /* Photo click: three party tricks, cycled per click */
  @keyframes photo-spin {
    from { transform: rotate(0) scale(1); }
    40%  { transform: rotate(-9deg) scale(1.1); }
    to   { transform: rotate(360deg) scale(1); }
  }
  @keyframes photo-squish {
    0%, 100% { transform: scale(1, 1); }
    30%      { transform: scale(1.18, 0.82); }
    60%      { transform: scale(0.88, 1.14); }
  }
  @keyframes photo-jump {
    0%, 100% { transform: translateY(0) rotate(0); }
    35%      { transform: translateY(-26px) rotate(-5deg); }
    65%      { transform: translateY(4px) rotate(3deg); }
  }
  .romance-photo.click-spin   { animation: photo-spin   0.8s cubic-bezier(0.34, 1.4, 0.5, 1); }
  .romance-photo.click-squish { animation: photo-squish 0.6s cubic-bezier(0.34, 1.56, 0.64, 1); }
  .romance-photo.click-jump   { animation: photo-jump   0.7s cubic-bezier(0.34, 1.56, 0.64, 1); }

  /* Hearts burst out of the photo on click */
  #single-photo-wrap .burst-heart {
    position: absolute;
    top: 50%;
    left: 50%;
    font-size: 1.5rem;
    pointer-events: none;
    z-index: 5;
    animation: heart-burst 1s cubic-bezier(0.2, 0.6, 0.3, 1) forwards;
  }
  @keyframes heart-burst {
    0%   { transform: translate(-50%, -50%) scale(0.4); opacity: 0; }
    20%  { opacity: 1; }
    100% {
      transform:
        translate(calc(-50% + var(--dx)), calc(-50% + var(--dy)))
        scale(1.15)
        rotate(var(--rot));
      opacity: 0;
    }
  }

  /* ── Scroll-driven motion (progressive enhancement) ───────────
     Browsers with CSS scroll-driven animations get: the hero content
     drifting up and fading as you scroll away (parallax depth), and
     the orb layer sliding at a different rate. Everyone else keeps
     the standard reveal — nothing breaks. */
  @supports (animation-timeline: scroll()) {
    @media (prefers-reduced-motion: no-preference) {
      .romance .hero-mesh .max-w-wrap {
        animation: hero-recede linear both;
        animation-timeline: scroll(root);
        animation-range: 0 90vh;
      }
      .romance-orb-layer {
        animation: orb-recede linear both;
        animation-timeline: scroll(root);
        animation-range: 0 120vh;
      }
    }
  }
  @keyframes hero-recede {
    to { transform: translateY(9rem); opacity: 0.15; }
  }
  @keyframes orb-recede {
    to { transform: translateY(-14rem) rotate(8deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .romance-orb,
    .romance-photo,
    .heartbeat,
    .romance .card-flow li:hover > span:first-child,
    .romance-photo.click-spin,
    .romance-photo.click-squish,
    .romance-photo.click-jump,
    #single-photo-wrap .burst-heart {
      animation: none !important;
    }
  }
</style>

<script>
  // Age derives from the birthday (Dec 10, 1999) at view time — never
  // hardcoded, never needs a manual bump.
  function initSinglePage() {
    const el = document.getElementById('single-age');
    if (!el || (el as HTMLElement).dataset.init) return;
    (el as HTMLElement).dataset.init = '1';

    const now = new Date();
    let age = now.getFullYear() - 1999;
    const birthdayThisYear = new Date(now.getFullYear(), 11, 10); // Dec 10
    if (now < birthdayThisYear) age -= 1;
    el.textContent = String(age);

    // Photo party tricks: every click runs the next animation in the
    // cycle and bursts a handful of hearts. Skipped (hearts included)
    // under reduced motion.
    const photo = document.getElementById('single-photo');
    const wrap = document.getElementById('single-photo-wrap');
    if (photo && wrap) {
      const tricks = ['click-squish', 'click-spin', 'click-jump'];
      let i = 0;
      photo.addEventListener('click', () => {
        if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        tricks.forEach((t) => photo.classList.remove(t));
        void (photo as HTMLElement).offsetWidth; // restart the animation
        photo.classList.add(tricks[i % tricks.length]);
        i += 1;

        const glyphs = ['💖', '💘', '❤️', '💝', '💗', '✨'];
        for (let k = 0; k < 6; k++) {
          const h = document.createElement('span');
          h.className = 'burst-heart';
          h.setAttribute('aria-hidden', 'true');
          h.textContent = glyphs[Math.floor(Math.random() * glyphs.length)];
          const angle = (k / 6) * Math.PI * 2 + Math.random() * 0.6;
          const dist = 100 + Math.random() * 70;
          h.style.setProperty('--dx', `${Math.cos(angle) * dist}px`);
          h.style.setProperty('--dy', `${Math.sin(angle) * dist}px`);
          h.style.setProperty('--rot', `${Math.random() * 80 - 40}deg`);
          wrap.appendChild(h);
          setTimeout(() => h.remove(), 1100);
        }
      });
    }

    // Instagram: a static site has no server to proxy the feed and
    // Instagram blocks anonymous cross-origin reads, so this attempt
    // is expected to fail — the designed fallback below stays up. If
    // Instagram ever loosens CORS for public profiles, the gallery
    // lights up without a code change.
    const gallery = document.getElementById('ig-gallery');
    const fallback = document.getElementById('ig-fallback');
    if (!gallery || !fallback) return;
    const controller = new AbortController();
    setTimeout(() => controller.abort(), 4000);
    fetch('https://www.instagram.com/api/v1/users/web_profile_info/?username=brianadolfocervantesalvarez', {
      signal: controller.signal,
      headers: { Accept: 'application/json' },
    })
      .then((r) => (r.ok ? r.json() : Promise.reject(new Error(String(r.status)))))
      .then((data) => {
        const edges = data?.data?.user?.edge_owner_to_timeline_media?.edges ?? [];
        const imgs = edges.slice(0, 8);
        if (imgs.length === 0) return;
        gallery.innerHTML = '';
        for (const { node } of imgs) {
          const a = document.createElement('a');
          a.href = 'https://www.instagram.com/brianadolfocervantesalvarez';
          a.target = '_blank';
          a.rel = 'noreferrer';
          const img = document.createElement('img');
          img.src = node.thumbnail_src || node.display_url;
          img.alt = node.accessibility_caption || 'Instagram photo';
          img.loading = 'lazy';
          img.className = 'w-full aspect-square object-cover rounded-xl border border-rule';
          a.appendChild(img);
          gallery.appendChild(a);
        }
        gallery.classList.remove('hidden');
        gallery.classList.add('grid');
        fallback.classList.add('hidden');
      })
      .catch(() => { /* fallback stays visible by design */ });
  }

  document.addEventListener('astro:page-load', initSinglePage);
  if (document.readyState !== 'loading') initSinglePage();
  else document.addEventListener('DOMContentLoaded', initSinglePage);
</script>
