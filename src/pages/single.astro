---
// src/pages/single.astro — the hidden "I'm Single BTW" page.
//
// Not linked from anywhere. Not in the sitemap (filtered in
// astro.config.ts). noindex'd below. The only way in is the
// five-click easter egg on the About page portrait — see about.astro.
import BaseLayout from '@layouts/BaseLayout.astro';
import LandingSection from '@components/LandingSection.astro';
import Button from '@components/Button.astro';
import StatusBanner from '@components/StatusBanner.astro';

const INSTAGRAM = 'https://www.instagram.com/brianadolfocervantesalvarez';

const identity = ['Mexican-American 🇲🇽🇺🇸', 'Dual citizen', 'Oregon', 'Data Scientist', 'AI Builder', 'Statistician'];

const education = [
  { degree: "Bachelor's", school: 'Linfield University', field: 'Mathematics', when: '',
    color: '#4B0082',
    logo: '/images/schools/linfield.svg', monogram: 'L' },
  { degree: "Master's", school: 'Willamette University', field: 'Data Science', when: '2023',
    color: '#A6093D',
    logo: '/images/schools/willamette.svg', monogram: 'WU' },
  { degree: "Master's", school: 'Oregon State University', field: 'Statistics', when: '2025',
    color: '#DC4405',
    logo: '/images/schools/oregon-state.svg', monogram: 'OSU' },
];

const hobbies = {
  regular: [
    { emoji: '🥐', label: 'Baking' },
    { emoji: '💪', label: 'Working Out' },
    { emoji: '🤖', label: 'AI & Data Science' },
    { emoji: '🎮', label: 'Video Games' },
    { emoji: '✈️', label: 'Traveling' },
  ],
  fresh: [
    { emoji: '🎣', label: 'Fishing' },
    { emoji: '🍷', label: 'Wine Tasting' },
    { emoji: '⚽', label: 'Soccer Matches' },
  ],
  nerd: [
    { emoji: '🌌', label: 'Star Wars' },
    { emoji: '🎌', label: 'Anime' },
    { emoji: '🎧', label: 'Audiophile' },
    { emoji: '🖥️', label: 'PC Building' },
    { emoji: '📱', label: 'Technology' },
  ],
};

const mexicanFoods = ['Pozole', 'Tamales', 'Mole', 'Enchiladas', 'Tacos al Pastor'];
const desserts = ['Cheesecake', 'Brownies', 'Lemon Loaf', 'Banana Bread'];

const goals = [
  { emoji: '👶', label: 'One child' },
  { emoji: '💞', label: 'Long-term relationship' },
  { emoji: '🌍', label: 'Travel together' },
  { emoji: '🥾', label: 'Local adventures' },
  { emoji: '🛫', label: 'International travel' },
  { emoji: '🌱', label: 'Shared growth' },
];

const lookingFor = [
  'Kind', 'Curious', 'Emotionally mature', 'Ambitious', 'Communicative',
  'Hygienic', 'Independent', 'Looking for something serious', 'Comfortable growing together',
];

const construction = [
  "Sometimes I'm too organized.",
  'I occasionally avoid addressing small annoyances longer than I should.',
  'I have a tendency to help so much that it can become overwhelming — please tell me if that happens.',
  "I'm trying to become more spiritually reflective.",
  'Some weeks I accidentally become a professional homebody because staying home is significantly cheaper.',
];
---
<BaseLayout title="I'm Single BTW" description="A hidden page for the curious.">
  <meta slot="head" name="robots" content="noindex,nofollow" />

  {/* data-pagefind-ignore="all": the site search must never surface
      the secret — this page stays out of the Pagefind index entirely */}
  <div data-pagefind-ignore="all" class="romance">

  <!-- ── Hero ─────────────────────────────────────────────────── -->
  <section class="tone-dark grain hero-mesh relative overflow-hidden pt-24 pb-20 lg:pt-28 lg:pb-24" aria-labelledby="single-hero-title">
    <div class="romance-orb-layer absolute inset-0" aria-hidden="true">
      <div class="romance-orb romance-orb-a"></div>
      <div class="romance-orb romance-orb-b"></div>
    </div>
    <div class="max-w-wrap mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-[auto_1fr] gap-10 lg:gap-14 items-center">
        <div class="relative justify-self-center" id="single-photo-wrap">
          <img
            id="single-photo"
            src="/images/profile.jpg"
            alt="Brian, smiling"
            loading="eager"
            width="288"
            height="288"
            draggable="false"
            class="romance-photo w-52 h-52 lg:w-72 lg:h-72 rounded-3xl object-cover [object-position:50%_25%] border border-rule-strong animate-el-fade select-none cursor-pointer"
          />
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted m-0 mb-4 animate-el-rise [animation-delay:120ms]">
            You found the hidden page 🎉 · Bienvenid@
          </p>
          <h1 id="single-hero-title" class="font-serif font-semibold text-ink text-display m-0 mb-4 animate-el-rise [animation-delay:220ms]">
            Brian
          </h1>
          <p class="text-lede text-ink font-semibold m-0 mb-1 animate-el-rise [animation-delay:300ms]">
            Status: Single <span class="heartbeat" aria-hidden="true">❤️</span> · <span id="single-age">—</span> years old
          </p>
          <p class="text-sm text-muted italic m-0 mb-6 animate-el-rise [animation-delay:340ms]">
            (This page will immediately be removed the day this becomes untrue.)
          </p>
          <ul class="flex flex-wrap gap-2 list-none m-0 p-0 mb-7 animate-el-rise [animation-delay:400ms]" aria-label="About me at a glance">
            {identity.map((t) => (
              <li class="text-[0.72rem] font-bold uppercase tracking-[0.13em] text-accent-ink bg-surface-soft border border-rule px-3 py-1.5 rounded-full m-0">
                {t}
              </li>
            ))}
          </ul>
          <p class="text-body max-w-[56ch] m-0 animate-el-rise [animation-delay:460ms]">
            I'm a naturally curious person who enjoys building things, learning
            constantly, and finding joy in both quiet evenings at home and
            exploring somewhere new. I'm looking for someone to build a
            meaningful, long-term life with.
          </p>
          <p class="text-sm text-muted italic m-0 mt-3 animate-el-rise [animation-delay:520ms]">
            Y sí, también hablo español — pregúntame lo que quieras 😉
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Education ────────────────────────────────────────────── -->
  <LandingSection
    id="single-education"
    n="01"
    eyebrow="Receipts · Los recibos"
    title="Education."
  >
    {/* Tossed graduation caps loop in the section background */}
    <div class="grad-caps absolute inset-0 pointer-events-none" aria-hidden="true">
      <span class="grad-cap" style="left: 6%;  top: 12%; animation-delay: 0s;   animation-duration: 6.5s;">🎓</span>
      <span class="grad-cap" style="left: 38%; top: 70%; animation-delay: 1.2s; animation-duration: 7.5s;">🎓</span>
      <span class="grad-cap" style="left: 64%; top: 16%; animation-delay: 2.4s; animation-duration: 6s;">🎓</span>
      <span class="grad-cap" style="left: 88%; top: 58%; animation-delay: 0.7s; animation-duration: 8s;">🎓</span>
      <span class="grad-cap" style="left: 18%; top: 44%; animation-delay: 3.1s; animation-duration: 7s;">🎓</span>
    </div>
    <ol class="grid grid-cols-1 md:grid-cols-3 gap-6 list-none m-0 p-0" data-stagger>
      {education.map((e) => (
        <li
          class="edu-card group relative overflow-hidden bg-surface border border-rule rounded-2xl m-0 flex flex-col transition-all duration-300"
          style={`--school-color: ${e.color};`}
        >
          <div class="edu-band relative overflow-hidden p-6 md:p-7 text-white">
            <span class="edu-watermark edu-monogram" aria-hidden="true">{e.monogram}</span>
            <img
              class="edu-watermark"
              src={e.logo}
              alt=""
              aria-hidden="true"
              loading="lazy"
              decoding="async"
              onload="this.closest('.edu-band')?.querySelector('.edu-monogram')?.remove()"
              onerror="this.remove()"
            />
            <p class="relative text-[0.7rem] font-bold uppercase tracking-[0.16em] opacity-85 m-0 mb-2">
              {e.degree}{e.when && ` · ${e.when}`}
            </p>
            <h3 class="relative font-serif font-semibold text-2xl tracking-tight leading-tight m-0 text-white">{e.school}</h3>
          </div>
          <div class="p-6 md:p-7 flex flex-col gap-5 flex-1">
            <p class="text-body text-sm font-semibold m-0 mt-auto">{e.field}</p>
          </div>
        </li>
      ))}
    </ol>

    {/* The next degree: wide Ph.D. goal banner in OSU colors */}
    <aside
      class="edu-card group relative overflow-hidden bg-surface border border-rule rounded-2xl mt-6 grid grid-cols-1 md:grid-cols-[1.15fr_1fr] transition-all duration-300"
      style="--school-color: #DC4405;"
      aria-labelledby="phd-goal-title"
    >
      <div class="edu-band relative overflow-hidden p-7 md:p-9 text-white">
        <span class="edu-watermark edu-monogram" aria-hidden="true">PhD</span>
        <p class="relative text-[0.7rem] font-bold uppercase tracking-[0.16em] opacity-85 m-0 mb-2">
          The one that's coming · La próxima meta 🎓
        </p>
        <h3 id="phd-goal-title" class="relative font-serif font-semibold text-2xl md:text-3xl tracking-tight leading-tight m-0 text-white">
          Ph.D. in Artificial Intelligence
        </h3>
        <p class="relative text-sm font-medium opacity-90 m-0 mt-4">
          Target start 2030–2032 · defended before 2035
        </p>
      </div>
      <div class="p-7 md:p-9 flex flex-col justify-center">
        <p class="text-body text-sm leading-relaxed m-0">
          The plan is set: keep shipping AI systems in production now, then
          formalize it with research. Likely home: Oregon State — I already
          look good in Beaver orange, and they know me.
        </p>
      </div>
    </aside>
  </LandingSection>

  <!-- ── Current chapter ──────────────────────────────────────── -->
  <LandingSection
    id="single-now"
    n="02"
    eyebrow="Life right now · La vida hoy"
    title="Current chapter."
    tone="tint"
  >
    <StatusBanner
      href="https://www.oregon.gov/ode/"
      org="Oregon Department of Education"
      role="Business Intelligence Analyst · Since Dec 8, 2025 — yes, this is the day job"
    />
    <div class="max-w-prose">
      <p class="text-body m-0 mb-4">
        I have a stable career that I genuinely enjoy, and my biggest
        financial priority right now is paying off my student loans — most
        of my disposable income is going toward becoming debt-free. I'm
        financially responsible and intentionally investing in my future,
        and honestly, it feels great.
      </p>
      <p class="text-body m-0">
        Because of that, I'm far more interested in meaningful experiences
        than expensive dates: coffee shops, cooking together, local
        adventures, long walks, museums, game nights, road trips, and
        simply spending quality time together. The best parts of getting to
        know someone were never behind a paywall anyway.
      </p>
    </div>

    {/* Where this is headed: salary milestones, stated plainly */}
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-10" data-stagger>
      {[
        { year: '2028', figure: '$100K', note: 'base salary' },
        { year: '2035', figure: '$150K', note: 'and climbing' },
        { year: '2040', figure: '$200K+', note: 'bare minimum' },
      ].map((m) => (
        <div class="bg-surface border border-rule rounded-2xl px-6 py-5 text-center transition-all duration-300 hover:-translate-y-0.5 hover:border-rule-strong">
          <p class="font-mono text-xs font-semibold text-muted tracking-[0.16em] uppercase m-0 mb-1">{m.year}</p>
          <p class="font-serif font-semibold text-ink text-3xl tracking-tight m-0">{m.figure}</p>
          <p class="text-xs text-muted m-0 mt-1">{m.note}</p>
        </div>
      ))}
    </div>

    <div class="max-w-prose mt-8">
      <p class="text-body m-0 mb-4">
        I aim for remote-friendly roles that keep me above the $100K line.
        With the State it's a slower ride — but that's realistic for
        government work, and the stability is the point. If I ever jump to
        the private sector, those numbers move up fast.
      </p>
      <p class="text-lede text-ink font-serif m-0">
        Financial stability is my ultimate goal.
        <span class="text-muted text-base italic"> La estabilidad primero — lo demás llega solito 😌</span>
      </p>
    </div>
  </LandingSection>

  <!-- ── Hobbies ──────────────────────────────────────────────── -->
  <LandingSection
    id="single-hobbies"
    n="03"
    eyebrow="How I spend my time"
    title="Hobbies."
  >
    <div class="flex flex-col gap-10">
      <div>
        <h3 class="text-sm font-bold uppercase tracking-[0.14em] text-ink m-0 mb-5">The regulars</h3>
        <ul class="card-flow list-none m-0 p-0" data-stagger>
          {hobbies.regular.map((h) => (
            <li class="bg-surface border border-rule rounded-2xl px-6 py-5 m-0 flex items-center gap-4 transition-all duration-300 hover:-translate-y-0.5 hover:border-rule-strong">
              <span class="text-3xl" aria-hidden="true">{h.emoji}</span>
              <span class="font-semibold text-ink">{h.label}</span>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-bold uppercase tracking-[0.14em] text-ink m-0 mb-5">New this year</h3>
        <ul class="card-flow list-none m-0 p-0" data-stagger>
          {hobbies.fresh.map((h) => (
            <li class="bg-surface border border-rule rounded-2xl px-6 py-5 m-0 flex items-center gap-4 transition-all duration-300 hover:-translate-y-0.5 hover:border-rule-strong">
              <span class="text-3xl" aria-hidden="true">{h.emoji}</span>
              <span class="font-semibold text-ink">{h.label}</span>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-bold uppercase tracking-[0.14em] text-ink m-0 mb-5">Nerd interests</h3>
        <ul class="card-flow list-none m-0 p-0" data-stagger>
          {hobbies.nerd.map((h) => (
            <li class="bg-surface border border-rule rounded-2xl px-6 py-5 m-0 flex items-center gap-4 transition-all duration-300 hover:-translate-y-0.5 hover:border-rule-strong">
              <span class="text-3xl" aria-hidden="true">{h.emoji}</span>
              <span class="font-semibold text-ink">{h.label}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </LandingSection>

  <!-- ── Favorites ────────────────────────────────────────────── -->
  <LandingSection
    id="single-favorites"
    n="04"
    eyebrow="The important data · La comida es amor"
    title="Favorite things."
    tone="tint"
  >
    <div class="card-flow" data-stagger>
      <div class="bg-surface border border-rule rounded-2xl p-7">
        <h3 class="text-sm font-bold uppercase tracking-[0.14em] text-ink m-0 mb-4">🍗 Food, generally</h3>
        <p class="text-body text-sm m-0">
          Anything involving chicken — except extremely greasy fried
          chicken. A man needs standards.
        </p>
      </div>
      <div class="bg-surface border border-rule rounded-2xl p-7">
        <h3 class="text-sm font-bold uppercase tracking-[0.14em] text-ink m-0 mb-4">🇲🇽 Mexican favorites</h3>
        <ul class="list-none m-0 p-0 flex flex-wrap gap-2">
          {mexicanFoods.map((f) => (
            <li class="text-sm font-semibold text-ink bg-surface-soft border border-rule px-3 py-1.5 rounded-full m-0">{f}</li>
          ))}
        </ul>
      </div>
      <div class="bg-surface border border-rule rounded-2xl p-7">
        <h3 class="text-sm font-bold uppercase tracking-[0.14em] text-ink m-0 mb-4">🍰 Desserts</h3>
        <ul class="list-none m-0 p-0 flex flex-wrap gap-2">
          {desserts.map((f) => (
            <li class="text-sm font-semibold text-ink bg-surface-soft border border-rule px-3 py-1.5 rounded-full m-0">{f}</li>
          ))}
        </ul>
      </div>
      <div class="bg-surface border border-rule rounded-2xl p-7">
        <h3 class="text-sm font-bold uppercase tracking-[0.14em] text-ink m-0 mb-4">🍷 Favorite wine</h3>
        <p class="text-body text-sm m-0">
          Stella Rosa. Yes, I know. No, I won't be taking questions. Salud 🥂
        </p>
      </div>
    </div>
  </LandingSection>

  <!-- ── Instagram ────────────────────────────────────────────── -->
  <LandingSection
    id="single-gram"
    n="05"
    eyebrow="Proof of life · Las pruebas 📸"
    title="From my Instagram."
    tone="dark"
  >
    {/* Floating Instagram glyphs drift in the band background */}
    <div class="ig-floaters absolute inset-0 pointer-events-none" aria-hidden="true">
      {[
        'left: 8%;  top: 18%; animation-delay: 0s;    animation-duration: 9s;  --sz: 3.2rem;',
        'left: 78%; top: 12%; animation-delay: 1.6s;  animation-duration: 11s; --sz: 4.4rem;',
        'left: 30%; top: 72%; animation-delay: 3s;    animation-duration: 10s; --sz: 2.6rem;',
        'left: 90%; top: 66%; animation-delay: 0.8s;  animation-duration: 8s;  --sz: 3rem;',
        'left: 55%; top: 34%; animation-delay: 2.2s;  animation-duration: 12s; --sz: 5rem;',
      ].map((style) => (
        <svg class="ig-floater" style={style} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <rect x="2.5" y="2.5" width="19" height="19" rx="5.5" />
          <circle cx="12" cy="12" r="4.5" />
          <circle cx="17.3" cy="6.7" r="1.3" fill="currentColor" stroke="none" />
        </svg>
      ))}
    </div>
    <div id="ig-gallery" class="hidden grid-cols-2 md:grid-cols-4 gap-4 mb-8"></div>
    <div id="ig-fallback" class="bg-surface border border-rule rounded-2xl px-8 py-12 text-center">
      <p class="text-lede text-ink m-0 mb-2">Looks like Instagram is being stubborn today.</p>
      <p class="text-sm text-muted m-0 mb-7">
        Europe trips, educational milestones, and other questionable
        adventures live over there. Dale follow, no seas tímide 😏
      </p>
      <Button href={INSTAGRAM} target="_blank" rel="noreferrer">View my Instagram →</Button>
    </div>
  </LandingSection>

  <!-- ── Relationship goals ───────────────────────────────────── -->
  <LandingSection
    id="single-goals"
    n="06"
    eyebrow="The long game"
    title="Relationship goals."
  >
    <ul class="card-flow list-none m-0 p-0 mb-8" data-stagger>
      {goals.map((g) => (
        <li class="bg-surface border border-rule rounded-2xl px-6 py-5 m-0 flex items-center gap-4 transition-all duration-300 hover:-translate-y-0.5 hover:border-rule-strong">
          <span class="text-3xl" aria-hidden="true">{g.emoji}</span>
          <span class="font-semibold text-ink">{g.label}</span>
        </li>
      ))}
    </ul>
    <div class="card-flow">
      <div class="bg-surface-soft border border-rule rounded-2xl p-7">
        <h3 class="text-sm font-bold uppercase tracking-[0.14em] text-ink m-0 mb-3">⛪ Religion</h3>
        <p class="text-body text-sm m-0">
          Culturally Catholic, practically agnostic. Open-minded and
          respectful either way.
        </p>
      </div>
      <div class="bg-surface-soft border border-rule rounded-2xl p-7">
        <h3 class="text-sm font-bold uppercase tracking-[0.14em] text-ink m-0 mb-3">🐈 Pets</h3>
        <p class="text-body text-sm m-0">
          Love animals. If choosing one: cats. Hard maximum of two —
          this is a household, not a sanctuary.
        </p>
      </div>
      <div class="bg-surface-soft border border-rule rounded-2xl p-7">
        <h3 class="text-sm font-bold uppercase tracking-[0.14em] text-ink m-0 mb-3">💬 Love languages</h3>
        <p class="text-body text-sm m-0">
          ❤️ Acts of Service · 🤝 Physical Touch
        </p>
      </div>
    </div>

    <aside class="mt-8 bg-surface border-l-4 border-accent border border-rule rounded-2xl px-7 py-6" aria-label="Random fact">
      <p class="text-body m-0">
        <strong class="text-ink">Random fact:</strong> believe it or not, my
        longest relationship lasted three months... in middle school. So
        yes, we're setting a very achievable record here.
      </p>
    </aside>
  </LandingSection>

  <!-- ── Looking for ──────────────────────────────────────────── -->
  <LandingSection
    id="single-looking"
    n="07"
    eyebrow="The good stuff"
    title="What I'm looking for."
    tone="tint"
  >
    <div class="max-w-prose mb-8">
      <p class="text-body m-0">
        Someone I genuinely like being around — kind by default, curious
        about the world, emotionally mature when things get real, ambitious
        about their own life, and communicative enough that neither of us
        ever has to guess. Someone who takes care of themselves, stands on
        their own, wants something serious, and is comfortable with the
        idea that we'd both keep growing.
      </p>
    </div>
    <ul class="flex flex-wrap gap-2 list-none m-0 p-0" aria-label="Qualities that matter to me">
      {lookingFor.map((q) => (
        <li class="text-sm font-semibold text-ink bg-surface border border-rule px-4 py-2 rounded-full m-0">{q}</li>
      ))}
    </ul>
  </LandingSection>

  <!-- ── Compatibility ────────────────────────────────────────── -->
  <LandingSection
    id="single-compat"
    n="08"
    eyebrow="Honest calibration · Sin rodeos"
    title="We'd probably be compatible if..."
  >
    <div class="max-w-prose">
      <p class="text-body m-0 mb-4">
        You're not highly religious, you have goals and ambitions of your
        own, and you communicate consistently — disappearing for days is
        the one pattern I can't build anything on. You don't smoke or use
        recreational drugs, and you value personal hygiene the way I do.
      </p>
      <p class="text-body m-0 mb-4">
        You're interested in building a long-term partnership rather than
        rushing milestones: I don't see marriage within the first five
        years of dating, and I wouldn't want children before marriage. At
        this stage of my life, I'm generally not looking to date someone
        who already has children.
      </p>
      <p class="text-body m-0">
        On politics: shared core values and respect for individual rights
        matter to me. I'm an Progressive Independent + compatibility on the big
        life questions is the thing worth checking.
      </p>
    </div>
  </LandingSection>

  <!-- ── Bonus points ─────────────────────────────────────────── -->
  <LandingSection
    id="single-bonus"
    n="09"
    eyebrow="Nice-to-haves, not requirements"
    title="Bonus points."
    tone="tint"
  >
    <div class="max-w-prose mb-8">
      <p class="text-body m-0 mb-4">
        None of these are expectations — but if you're financially
        responsible, understand budgeting, keep a savings mindset, or get
        genuinely excited about investing, CDs, and retirement planning,
        we'll have plenty to talk about.
      </p>
      <p class="text-body m-0 mb-4">
        Since I'm aggressively paying off student loans, I'm much happier
        with homemade dinners, coffee dates, bookstores, hiking, museums,
        and weekend adventures than expensive gifts or luxury restaurants.
      </p>
      <p class="text-body m-0">
        On alcohol: I'm perfectly happy enjoying wine or cocktails
        occasionally, but I don't want it to become the centerpiece of
        every outing.
      </p>
    </div>
  </LandingSection>

  <!-- ── Under construction ───────────────────────────────────── -->
  <LandingSection
    id="single-construction"
    n="10"
    eyebrow="Full disclosure"
