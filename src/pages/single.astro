<script>
  // Age derives from the birthday (Dec 10, 1999) at view time — never
  // hardcoded, never needs a manual bump.
  function initSinglePage() {
    const el = document.getElementById('single-age');
    if (!el || (el as HTMLElement).dataset.init) return;
    (el as HTMLElement).dataset.init = '1';

    const now = new Date();
    let age = now.getFullYear() - 1999;
    const birthdayThisYear = new Date(now.getFullYear(), 11, 10); // Dec 10
    if (now < birthdayThisYear) age -= 1;
    el.textContent = String(age);

    // Photo party tricks: every click runs the next animation in the
    // cycle and bursts a handful of hearts. Skipped (hearts included)
    // under reduced motion.
    const photo = document.getElementById('single-photo');
    const wrap = document.getElementById('single-photo-wrap');
    if (photo && wrap) {
      const tricks = ['click-squish', 'click-spin', 'click-jump'];
      let i = 0;
      photo.addEventListener('click', () => {
        if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        tricks.forEach((t) => photo.classList.remove(t));
        void (photo as HTMLElement).offsetWidth; // restart the animation
        photo.classList.add(tricks[i % tricks.length]);
        i += 1;

        const glyphs = ['💖', '💘', '❤️', '💝', '💗', '✨'];
        for (let k = 0; k < 6; k++) {
          const h = document.createElement('span');
          h.className = 'burst-heart';
          h.setAttribute('aria-hidden', 'true');
          h.textContent = glyphs[Math.floor(Math.random() * glyphs.length)];
          const angle = (k / 6) * Math.PI * 2 + Math.random() * 0.6;
          const dist = 100 + Math.random() * 70;
          h.style.setProperty('--dx', `${Math.cos(angle) * dist}px`);
          h.style.setProperty('--dy', `${Math.sin(angle) * dist}px`);
          h.style.setProperty('--rot', `${Math.random() * 80 - 40}deg`);
          wrap.appendChild(h);
          setTimeout(() => h.remove(), 1100);
        }
      });
    }

    // Instagram: a static site has no server to proxy the feed and
    // Instagram blocks anonymous cross-origin reads, so this attempt
    // is expected to fail — the designed fallback below stays up. If
    // Instagram ever loosens CORS for public profiles, the gallery
    // lights up without a code change.
    const gallery = document.getElementById('ig-gallery');
    const fallback = document.getElementById('ig-fallback');
    if (!gallery || !fallback) return;
    const controller = new AbortController();
    setTimeout(() => controller.abort(), 4000);
    fetch('https://www.instagram.com/api/v1/users/web_profile_info/?username=brianadolfocervantesalvarez', {
      signal: controller.signal,
      headers: { Accept: 'application/json' },
    })
      .then((r) => (r.ok ? r.json() : Promise.reject(new Error(String(r.status)))))
      .then((data) => {
        const edges = data?.data?.user?.edge_owner_to_timeline_media?.edges ?? [];
        const imgs = edges.slice(0, 8);
        if (imgs.length === 0) return;
        gallery.innerHTML = '';
        for (const { node } of imgs) {
          const a = document.createElement('a');
          a.href = 'https://www.instagram.com/brianadolfocervantesalvarez';
          a.target = '_blank';
          a.rel = 'noreferrer';
          const img = document.createElement('img');
          img.src = node.thumbnail_src || node.display_url;
          img.alt = node.accessibility_caption || 'Instagram photo';
          img.loading = 'lazy';
          img.className = 'w-full aspect-square object-cover rounded-xl border border-rule';
          a.appendChild(img);
          gallery.appendChild(a);
        }
        gallery.classList.remove('hidden');
        gallery.classList.add('grid');
        fallback.classList.add('hidden');
      })
      .catch(() => { /* fallback stays visible by design */ });
  }

  // Dish rail arrows: scroll the showcase one card at a time.
  document.addEventListener('click', (e) => {
    const t = e.target instanceof Element ? e.target : null;
    const btn = t?.closest('[data-rail-dir]');
    if (!btn) return;
    const rail = btn.closest('.dish-rail-wrap')?.querySelector('.dish-rail');
    if (!rail) return;
    const dir = Number(btn.getAttribute('data-rail-dir')) || 1;
    rail.scrollBy({ left: dir * 344, behavior: 'smooth' });
  });

  // "Text me 😉" — swap the button for the real number (sms: link),
  // delegated so it survives router swaps.
  document.addEventListener('click', (e) => {
    const t = e.target instanceof Element ? e.target : null;
    if (!t || !t.closest('#reveal-phone')) return;
    const btn = document.getElementById('reveal-phone');
    const phone = document.getElementById('phone-revealed');
    if (!btn || !phone) return;
    btn.hidden = true;
    phone.hidden = false;
    phone.focus?.();
  });

  document.addEventListener('astro:page-load', initSinglePage);
  if (document.readyState !== 'loading') initSinglePage();
  else document.addEventListener('DOMContentLoaded', initSinglePage);
</script>
