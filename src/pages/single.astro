<script>
  // Age derives from the birthday (Dec 10, 1999) at view time — never
  // hardcoded, never needs a manual bump.
  function initSinglePage() {
    const el = document.getElementById('single-age');
    if (!el || (el as HTMLElement).dataset.init) return;
    (el as HTMLElement).dataset.init = '1';

    const now = new Date();
    let age = now.getFullYear() - 1999;
    const birthdayThisYear = new Date(now.getFullYear(), 11, 10); // Dec 10
    if (now < birthdayThisYear) age -= 1;
    el.textContent = String(age);

    // Photo party tricks: every click runs the next animation in the
    // cycle and bursts a handful of hearts. Skipped (hearts included)
    // under reduced motion.
    const photo = document.getElementById('single-photo');
    const wrap = document.getElementById('single-photo-wrap');
    if (photo && wrap) {
      const tricks = ['click-squish', 'click-spin', 'click-jump'];
      let i = 0;
      photo.addEventListener('click', () => {
        if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        tricks.forEach((t) => photo.classList.remove(t));
        void (photo as HTMLElement).offsetWidth; // restart the animation
        photo.classList.add(tricks[i % tricks.length]);
        i += 1;

        const glyphs = ['💖', '💘', '❤️', '💝', '💗', '✨'];
        for (let k = 0; k < 6; k++) {
          const h = document.createElement('span');
          h.className = 'burst-heart';
          h.setAttribute('aria-hidden', 'true');
          h.textContent = glyphs[Math.floor(Math.random() * glyphs.length)];
          const angle = (k / 6) * Math.PI * 2 + Math.random() * 0.6;
          const dist = 100 + Math.random() * 70;
          h.style.setProperty('--dx', `${Math.cos(angle) * dist}px`);
          h.style.setProperty('--dy', `${Math.sin(angle) * dist}px`);
          h.style.setProperty('--rot', `${Math.random() * 80 - 40}deg`);
          wrap.appendChild(h);
          setTimeout(() => h.remove(), 1100);
        }
      });
    }

    // Instagram: a static site has no server to proxy the feed and
    // Instagram blocks anonymous cross-origin reads, so this attempt
    // is expected to fail — the designed fallback below stays up. If
    // Instagram ever loosens CORS for public profiles, the gallery
    // lights up without a code change.
    const gallery = document.getElementById('ig-gallery');
    const fallback = document.getElementById('ig-fallback');
    if (!gallery || !fallback) return;
    const controller = new AbortController();
    setTimeout(() => controller.abort(), 4000);
    fetch('https://www.instagram.com/api/v1/users/web_profile_info/?username=brianadolfocervantesalvarez', {
      signal: controller.signal,
      headers: { Accept: 'application/json' },
    })
      .then((r) => (r.ok ? r.json() : Promise.reject(new Error(String(r.status)))))
      .then((data) => {
        const edges = data?.data?.user?.edge_owner_to_timeline_media?.edges ?? [];
        const imgs = edges.slice(0, 8);
        if (imgs.length === 0) return;
        gallery.innerHTML = '';
        for (const { node } of imgs) {
          const a = document.createElement('a');
          a.href = 'https://www.instagram.com/brianadolfocervantesalvarez';
          a.target = '_blank';
          a.rel = 'noreferrer';
          const img = document.createElement('img');
          img.src = node.thumbnail_src || node.display_url;
          img.alt = node.accessibility_caption || 'Instagram photo';
          img.loading = 'lazy';
          img.className = 'w-full aspect-square object-cover rounded-xl border border-rule';
          a.appendChild(img);
          gallery.appendChild(a);
        }
        gallery.classList.remove('hidden');
        gallery.classList.add('grid');
        fallback.classList.add('hidden');
      })
      .catch(() => { /* fallback stays visible by design */ });
  }

  // Real poster art, resolved per card through a fallback chain:
  //   1. curated local file — /images/posters/<slug>.{jpg,png,webp}
  //      (the drop-zone; a file there ALWAYS wins)
  //   2. TVmaze by pinned show ID (series only) — keyless + CORS-open,
  //      canonical 2:3 portrait posters, incl. Mexican TV
  //   3. iTunes Search API — keyless + CORS-open; strong for films
  //   4. Wikipedia pageimages with pilicense=any — free OR fair-use art
  // Automatic sources must deliver true PORTRAIT art (height ≥ 1.2×
  // width, like a real 2:3 one-sheet): wide logos, landscape key art,
  // and square bundle covers all crop to mush in the card, so they're
  // rejected and the chain moves on. Only curated drop-zone files are
  // exempt — they render as-is (wide ones contained on the hue
  // backdrop). Once art lands, the emoji placeholder fades away; if
  // every step misses it stays.
  function tryPoster(media: HTMLElement, src: string, curated = false): Promise<boolean> {
    return new Promise((resolve) => {
      if (media.querySelector('.poster-img')) { resolve(true); return; }
      const img = document.createElement('img');
      img.className = 'poster-img';
      img.alt = '';
      img.decoding = 'async';
      img.addEventListener('load', () => {
        const portrait = img.naturalHeight > img.naturalWidth * 1.2;
        if (!portrait && !curated) { img.remove(); resolve(false); return; }
        if (img.naturalWidth > img.naturalHeight * 1.05) img.classList.add('poster-wide');
        img.classList.add('is-loaded');
        media.classList.add('has-art');
        resolve(true);
      });
      img.addEventListener('error', () => { img.remove(); resolve(false); });
      img.src = src;
      media.appendChild(img);
    });
  }

  async function tvmazeArt(id: string): Promise<string | null> {
    if (!id) return null;
    try {
      const r = await fetch(`https://api.tvmaze.com/shows/${id}`);
      if (!r.ok) return null;
      const data = await r.json();
      return data.image?.original ?? data.image?.medium ?? null;
    } catch { return null; }
  }

  async function itunesArt(q: string, m: string, c: string): Promise<string | null> {
    if (!q) return null;
    try {
      const url =
        'https://itunes.apple.com/search?limit=4' +
        `&media=${m === 'movie' ? 'movie' : 'tvShow'}` +
        `&entity=${m === 'movie' ? 'movie' : 'tvSeason'}` +
        `&country=${c || 'us'}&term=${encodeURIComponent(q)}`;
      const r = await fetch(url);
      if (!r.ok) return null;
      const data = await r.json();
      const hit = (data.results ?? []).find((x: { artworkUrl100?: string }) => x.artworkUrl100);
      // 100x100bb thumbnails rescale on demand; 600x900bb fits the
      // original-aspect artwork inside 600x900, so portrait posters
      // come back at full card resolution.
      return hit ? (hit.artworkUrl100 as string).replace('100x100bb', '600x900bb') : null;
    } catch { return null; }
  }

  async function wikiArt(title: string): Promise<string | null> {
    if (!title) return null;
    try {
      const url =
        'https://en.wikipedia.org/w/api.php?action=query&format=json&formatversion=2&origin=*' +
        '&prop=pageimages&piprop=thumbnail&pithumbsize=640&pilicense=any&redirects=1&titles=' +
        encodeURIComponent(title);
      const r = await fetch(url, { headers: { Accept: 'application/json' } });
      if (!r.ok) return null;
      const data = await r.json();
      return data.query?.pages?.[0]?.thumbnail?.source ?? null;
    } catch { return null; }
  }

  async function resolvePoster(media: HTMLElement) {
    const { slug = '', tvz = '', q = '', m = '', c = '', wiki = '' } = media.dataset;
    // Local drop-zone first — checked before the cache so a freshly
    // dropped file wins immediately over a previously cached lookup.
    for (const ext of ['jpg', 'png', 'webp']) {
      if (await tryPoster(media, `/images/posters/${slug}.${ext}`, true)) return;
    }
    // "poster2" key: v1 cached pre-portrait-check art — leave it behind.
    const key = `poster2:${slug || wiki}`;
    const cached = sessionStorage.getItem(key);
    if (cached && await tryPoster(media, cached)) return;
    for (const get of [() => tvmazeArt(tvz), () => itunesArt(q, m, c), () => wikiArt(wiki)]) {
      const src = await get();
      if (src && await tryPoster(media, src)) {
        try { sessionStorage.setItem(key, src); } catch { /* full */ }
        return;
      }
    }
  }

  function loadPosters() {
    document.querySelectorAll<HTMLElement>('.poster-media[data-slug]').forEach((media) => {
      if (media.dataset.posterDone) return;
      media.dataset.posterDone = '1';
      resolvePoster(media);
    });
  }
  document.addEventListener('astro:page-load', loadPosters);
  if (document.readyState !== 'loading') loadPosters();
  else document.addEventListener('DOMContentLoaded', loadPosters);

  // Dish rail arrows: scroll the showcase one card at a time.
  document.addEventListener('click', (e) => {
    const t = e.target instanceof Element ? e.target : null;
    const btn = t?.closest('[data-rail-dir]');
    if (!btn) return;
    const rail = btn.closest('.dish-rail-wrap')?.querySelector('.dish-rail');
    if (!rail) return;
    const dir = Number(btn.getAttribute('data-rail-dir')) || 1;
    rail.scrollBy({ left: dir * 344, behavior: 'smooth' });
  });

  // "Text me 😉" — swap the button for the real number (sms: link),
  // delegated so it survives router swaps.
  document.addEventListener('click', (e) => {
    const t = e.target instanceof Element ? e.target : null;
    if (!t || !t.closest('#reveal-phone')) return;
    const btn = document.getElementById('reveal-phone');
    const phone = document.getElementById('phone-revealed');
    if (!btn || !phone) return;
    btn.hidden = true;
    phone.hidden = false;
    phone.focus?.();
  });

  document.addEventListener('astro:page-load', initSinglePage);
  if (document.readyState !== 'loading') initSinglePage();
  else document.addEventListener('DOMContentLoaded', initSinglePage);
</script>
