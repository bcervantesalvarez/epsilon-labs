---
import BaseLayout from '@layouts/BaseLayout.astro';
import Button from '@components/Button.astro';
---
<BaseLayout title="Thank you" description="Form submission received.">
  {/* Renders into BaseLayout's head slot — keep this a bare <meta>,
      not a nested <head> element */}
  <meta slot="head" name="robots" content="noindex,nofollow" />

  <div class="ed">

    <section class="pt-24 pb-12 lg:pt-28 lg:pb-16 text-center">
      <div class="max-w-wrap mx-auto px-6">
        {/* stroke="currentColor" + text-status: var() is unreliable inside
            SVG presentation attributes, so the token flows in via `color` */}
        <svg id="ty-check" width="72" height="72" viewBox="0 0 56 56" aria-hidden="true" class="mx-auto mb-5 text-status">
          <circle cx="28" cy="28" r="25" fill="none" stroke="currentColor" stroke-width="3" opacity="0.18" />
          <circle cx="28" cy="28" r="25" fill="none" stroke="currentColor" stroke-width="3"
                  stroke-dasharray="157" stroke-dashoffset="157">
            <animate attributeName="stroke-dashoffset" from="157" to="0" dur="0.7s" fill="freeze" />
          </circle>
          <polyline points="16,30 25,38 40,20" fill="none" stroke="currentColor"
                    stroke-width="4" stroke-linecap="round" stroke-linejoin="round"
                    stroke-dasharray="40" stroke-dashoffset="40">
            <animate attributeName="stroke-dashoffset" from="40" to="0" dur="0.5s" begin="0.3s" fill="freeze" />
          </polyline>
        </svg>
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted m-0 mb-3">Message received</p>
        <h1 class="font-serif font-semibold text-ink text-5xl md:text-6xl tracking-tight leading-[1.06] m-0 mb-4">
          Thanks — I got it.
        </h1>
        <p class="text-lede text-body max-w-[52ch] mx-auto m-0 mb-7">
          I'll review your message and reply by email. Redirecting you
          home in <span id="ty-sec">15</span> seconds.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <Button href="/">Go home</Button>
          <Button href="/projects" variant="ghost">Projects</Button>
        </div>
      </div>
    </section>

    <script>
      // SMIL <animate> ignores CSS reduced-motion rules — jump the
      // checkmark draw to its finished frame and freeze it instead.
      const check = document.getElementById('ty-check');
      if (
        check instanceof SVGSVGElement &&
        matchMedia('(prefers-reduced-motion: reduce)').matches
      ) {
        check.setCurrentTime(2);
        check.pauseAnimations();
      }

      let secs = 15;
      const el = document.getElementById('ty-sec');
      const t = setInterval(() => {
        secs--; el && (el.textContent = String(secs));
        if (secs <= 0) { clearInterval(t); location.href = '/'; }
      }, 1000);
    </script>

  </div>
</BaseLayout>
